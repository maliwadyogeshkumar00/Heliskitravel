---
// Shared layout: one source of truth for <head>, header and footer across every page.
const { title, description = '', active = '', image, schema, heroImage } = Astro.props;
const LOGO = '/_vercel/image?url=https%3A%2F%2Fheliskitravel.com%2Fwp-content%2Fuploads%2F2026%2F05%2FHeliski-Updated-Logo.webp&w=320&q=80';
const pkgActive = active === 'packages';
const SITE = 'https://heliskitravel.vercel.app';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = SITE + (path === '/' ? '' : path);
const ogImage = SITE + (image || '/images/packages-hero.jpg');

// ---- Breadcrumbs (auto from path; package detail pages nest under Packages) ----
const LABELS = {
  'packages':'Packages','classic-heliskiing':'Classic Heliskiing','heli-assisted-touring':'Heli-Assisted Touring',
  'private-heliskiing':'Private Heliskiing','travel-here':'Travel Here','siglo-hotel':'Sigló Hotel',
  'iceland':'Iceland','gallery':'Gallery','about':'About Us','contact':'Contact',
  'privacy-policy':'Privacy Policy','terms':'Terms & Conditions','cookie-policy':'Cookie Policy','imprint':'Imprint'
};
const PARENT = { 'classic-heliskiing':'packages','heli-assisted-touring':'packages','private-heliskiing':'packages' };
const slug = path.replace(/^\//,'');
const crumbTrail = [];
if (slug) {
  if (PARENT[slug]) crumbTrail.push(PARENT[slug]);
  crumbTrail.push(slug);
}
const breadcrumbItems = [{ name:'Home', url:SITE + '/' }].concat(
  crumbTrail.map((s) => ({ name: LABELS[s] || s, url: SITE + '/' + s }))
);
const breadcrumbLd = slug ? {
  "@type":"BreadcrumbList",
  "itemListElement": breadcrumbItems.map((it, i) => ({
    "@type":"ListItem","position": i+1, "name": it.name, "item": it.url
  }))
} : null;

// ---- Core entity graph (LocalBusiness/TravelAgency + WebSite + WebPage) ----
const orgLd = {
  "@type":"TravelAgency",
  "@id": SITE + "/#org",
  "name":"Heliski Travel",
  "url": SITE,
  "logo": { "@type":"ImageObject", "url": SITE + "/logo-google.png", "width":600, "height":600 },
  "image": ogImage,
  "email":"hello@heliskitravel.com",
  "telephone":"+41797030917",
  "priceRange":"€€€€",
  "description":"Authorised booking agent for Viking Heliskiing in Siglufjörður, North Iceland — 3, 4 and 5-day heliskiing weeks with IFMGA-certified guides, based at the 4-star Sigló Hótel.",
  "areaServed":{ "@type":"Place","name":"Troll Peninsula, North Iceland","geo":{ "@type":"GeoCoordinates","latitude":66.1516,"longitude":-18.9075 } },
  "knowsAbout":["Heliskiing","Off-piste skiing","Ski touring","Troll Peninsula","Siglufjörður","Viking Heliskiing","Iceland ski holidays","Sigló Hótel"],
  "contactPoint":[{ "@type":"ContactPoint","contactType":"reservations","email":"hello@heliskitravel.com","telephone":"+41797030917","availableLanguage":["en"] }]
};
const websiteLd = { "@type":"WebSite", "@id": SITE + "/#website", "url": SITE, "name":"Heliski Travel", "publisher": { "@id": SITE + "/#org" } };
const webpageLd = { "@type":"WebPage", "@id": canonical + "#webpage", "url": canonical, "name": title, "isPartOf": { "@id": SITE + "/#website" }, "about": { "@id": SITE + "/#org" }, ...(description ? { "description": description } : {}) };
const graph = [orgLd, websiteLd, webpageLd];
if (breadcrumbLd) graph.push(breadcrumbLd);
if (Array.isArray(schema)) graph.push(...schema);
else if (schema) graph.push(schema);
const jsonLd = { "@context":"https://schema.org", "@graph": graph };
const FAVICON = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230A1628'/%3E%3Cpath d='M5 24 L13 11 L18 19 L21 15 L27 24 Z' fill='%23A8CFE0'/%3E%3Ccircle cx='23' cy='9' r='2' fill='%23C3DCEE'/%3E%3C/svg%3E";
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {/* LCP hero preload FIRST — before title/meta so the preload scanner starts the hero fetch immediately. Responsive: tiny 768w on mobile, full on desktop. */}
  {heroImage && (
    <>
      <link rel="preload" as="image" href={`/images/${heroImage}-768.webp`} media="(max-width: 767px)" fetchpriority="high" />
      <link rel="preload" as="image" href={`/images/${heroImage}.webp`} media="(min-width: 768px)" fetchpriority="high" />
    </>
  )}
  {path === '/' && (
    <>
      <link rel="preload" as="image" href="/videos/heli-poster-mobile.webp" media="(max-width: 767px)" fetchpriority="high" />
      <link rel="preload" as="image" href="/videos/heli-poster.webp" media="(min-width: 768px)" fetchpriority="high" />
    </>
  )}
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A1628" />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Heliski Travel" />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="800" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />
  <!-- Self-hosted fonts (in-house — no render-blocking external CSS). Preload only the above-the-fold weights. -->
  <link rel="preload" href="/fonts/mulish-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-500-italic.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face{font-family:'Mulish';font-style:normal;font-weight:300;font-display:swap;src:url('/fonts/mulish-300.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/mulish-400.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/mulish-500.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:600;font-display:swap;src:url('/fonts/mulish-600.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:700;font-display:swap;src:url('/fonts/mulish-700.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/cormorant-400.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/cormorant-500.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:400;font-display:swap;src:url('/fonts/cormorant-400-italic.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:500;font-display:swap;src:url('/fonts/cormorant-500-italic.woff2') format('woff2');}
  </style>
  {/* Fonts are fully self-hosted (Mulish + Cormorant Garamond) — no external font CSS, no third-party
      DNS/TLS on the critical path, and no Content-Security-Policy exceptions needed. */}
  {/* Prefetch the most likely next routes from the homepage — makes onward nav feel instant */}
  {path === '/' && (
    <>
      <link rel="prefetch" href="/packages" />
      <link rel="prefetch" href="/iceland" />
      <link rel="prefetch" href="/siglo-hotel" />
    </>
  )}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
<a href="#main" class="skip-link">Skip to content</a>
<div class="progress" id="progress" aria-hidden="true"></div>

<header id="siteHeader"><div class="shell nav">
  <a class="logo" href="/" aria-label="Heliski Travel home"><img src={LOGO} alt="Heliski Travel" width="220" height="108" fetchpriority="high" /></a>
  <button class="burger" id="burger" aria-label="Open menu" aria-controls="menu" aria-expanded="false"><span></span><span></span><span></span></button>
  <nav class="menu" id="menu" aria-label="Primary">
    <div class="menu__head"><a href="/" aria-label="Heliski Travel home"><img src={LOGO} alt="Heliski Travel" width="180" height="88" /></a></div>
    <span class="hassub"><a href="/packages" class={pkgActive ? 'active' : undefined}>Packages<span class="caret">▾</span></a><div class="submenu"><a href="/classic-heliskiing">Classic Heliskiing</a><a href="/heli-assisted-touring">Heli-Assisted Touring</a><a href="/private-heliskiing">Private Heliskiing</a></div></span>
    <a href="/travel-here" class={active === 'travel' ? 'active' : undefined}>Travel Here</a>
    <a href="/siglo-hotel" class={active === 'siglo' ? 'active' : undefined}>Sigló Hotel</a>
    <a href="/iceland" class={active === 'iceland' ? 'active' : undefined}>Iceland</a>
    <a href="/gallery" class={active === 'gallery' ? 'active' : undefined}>Gallery</a>
    <a href="/about" class={active === 'about' ? 'active' : undefined}>About Us</a>
    <a href="/contact" class={active === 'contact' ? 'active' : undefined}>Contact</a>
    <div class="menu__foot">
      <a class="mf__cta" href="/contact">Plan your trip <span>&rarr;</span></a>
      <a class="mf__mail" href="mailto:hello@heliskitravel.com">hello@heliskitravel.com</a>
      <div class="mf__tag">Authorised Agent · Viking Heliskiing Iceland</div>
      <div class="mf__base"><span>© 2026 Heliski Travel</span><span>Reply within 12 hours</span></div>
    </div>
  </nav>
</div></header>

<main id="main"><slot /></main>

<footer class="sf"><div class="shell">
  <div class="sf__top"><a class="logo" href="/" aria-label="Heliski Travel home"><img src={LOGO} alt="Heliski Travel" width="200" height="98" loading="lazy" /></a>
    <nav class="sf__nav" aria-label="Footer"><a href="/packages">Packages</a><a href="/travel-here">Travel Here</a><a href="/siglo-hotel">Sigló Hotel</a><a href="/iceland">Iceland</a><a href="/heliskiing-guide">Heliskiing Guide</a><a href="/gallery">Gallery</a><a href="/about">About Us</a><a href="/contact">Contact</a></nav></div>
  <div class="sf__mid"><a class="big" href="mailto:hello@heliskitravel.com">hello@heliskitravel.com</a><div class="sf__trust">Authorised Agent · Viking Heliskiing Iceland · Certified Guides · <b>Reply within 12 hours</b></div></div>
  <div class="sf__base"><span class="cr">© 2026 Heliski Travel. All Rights Reserved.</span><nav class="sf__legal" aria-label="Legal"><a href="/privacy-policy">Privacy Policy</a><a href="/terms">Terms &amp; Conditions</a><a href="/cookie-policy">Cookie Policy</a><a href="/imprint">Imprint</a></nav><a href="#siteHeader">Back to top ↑</a></div>
</div></footer>

<!-- floating action buttons -->
<div class="fab-stack hidden" id="fabStack">
  <button class="fab-hide" id="fabHide" type="button" aria-label="Hide contact buttons" title="Hide">&times;</button>
  <a class="fab fab--wa" href="https://wa.me/4794129999?text=Hi%20Heliski%20Travel%2C%20I%27d%20like%20to%20chat%20about%20a%20heliski%20week." target="_blank" rel="noopener" aria-label="Chat with us on WhatsApp">
    <svg viewBox="0 0 32 32" aria-hidden="true"><path d="M16 .5C7.4.5.5 7.4.5 16c0 2.82.74 5.46 2.04 7.75L.5 31.5l7.9-2.07A15.4 15.4 0 0 0 16 31.5c8.6 0 15.5-6.9 15.5-15.5S24.6.5 16 .5zm0 28.2c-2.5 0-4.83-.67-6.84-1.84l-.49-.29-4.69 1.23 1.25-4.57-.32-.5A12.66 12.66 0 0 1 3.3 16C3.3 8.98 8.98 3.3 16 3.3S28.7 8.98 28.7 16 23.02 28.7 16 28.7zm7.06-9.46c-.38-.19-2.28-1.12-2.63-1.25-.35-.13-.61-.19-.87.19-.26.38-1 1.25-1.23 1.51-.22.26-.45.29-.83.1-.38-.19-1.62-.6-3.08-1.9-1.14-1.02-1.91-2.28-2.13-2.66-.22-.38-.02-.59.17-.78.17-.17.38-.45.58-.67.19-.22.26-.38.38-.64.13-.26.06-.48-.03-.67-.1-.19-.87-2.09-1.19-2.86-.31-.75-.63-.65-.87-.66l-.74-.01c-.26 0-.67.1-1.02.48s-1.35 1.32-1.35 3.22 1.38 3.73 1.58 3.99c.19.26 2.72 4.15 6.59 5.82.92.4 1.64.64 2.2.82.92.29 1.76.25 2.42.15.74-.11 2.28-.93 2.6-1.83.32-.9.32-1.67.22-1.83-.09-.16-.35-.26-.73-.45z"/></svg>
    <span>Chat with us</span>
  </a>
  <a class="fab fab--primary" href="/contact" aria-label="Request a consultation">
    <span>Request consultation</span> <span class="arw">&#8594;</span>
  </a>
</div>
<button class="fab-launch show" id="fabShow" type="button" aria-label="Show contact options" title="Contact us">
  <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2C6.48 2 2 5.94 2 10.8c0 2.7 1.38 5.11 3.55 6.73L4.5 22l4.02-2.02c1.08.34 2.25.52 3.48.52 5.52 0 10-3.94 10-8.8S17.52 2 12 2z"/></svg>
</button>

<!-- Gallery lightbox (shared) -->
<div class="lb" id="lb" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb__x" id="lbX" type="button" aria-label="Close">&times;</button>
  <button class="lb__nav lb__prev" id="lbPrev" type="button" aria-label="Previous image">&#8249;</button>
  <img class="lb__img" id="lbImg" alt="" />
  <button class="lb__nav lb__next" id="lbNext" type="button" aria-label="Next image">&#8250;</button>
  <div class="lb__count" id="lbCount" aria-hidden="true"></div>
</div>
<style is:global>
.lb{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;background:rgba(8,16,28,.93);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);opacity:0;transition:opacity .35s cubic-bezier(.16,1,.3,1);}
.lb.open{display:flex;opacity:1;}
.lb__img{max-width:92vw;max-height:86vh;border-radius:4px;box-shadow:0 40px 90px rgba(0,0,0,.6);user-select:none;}
.lb__x,.lb__nav{position:absolute;border:0;background:rgba(244,246,248,.1);color:#F4F6F8;cursor:pointer;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .3s,transform .3s;}
.lb__x{top:22px;right:26px;width:46px;height:46px;font-size:24px;line-height:1;}
.lb__nav{top:50%;transform:translateY(-50%);width:54px;height:54px;font-size:30px;line-height:1;}
.lb__prev{left:24px;}.lb__next{right:24px;}
.lb__x:hover{background:rgba(168,207,224,.3);}
.lb__nav:hover{background:rgba(168,207,224,.3);}
.lb__count{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);font-size:12px;letter-spacing:.2em;color:rgba(195,220,238,.7);}
@media(max-width:700px){.lb__nav{width:44px;height:44px;font-size:24px;}.lb__prev{left:8px;}.lb__next{right:8px;}.lb__x{top:12px;right:12px;}.lb__img{max-width:96vw;}}
/* footer logo — constrained on every page (higher specificity wins over per-page rules) */
footer.sf .logo img{height:52px!important;width:auto!important;}
@media(max-width:900px){footer.sf .logo img{height:44px!important;}}
/* footer content width — match the rest of the site (per-page rule sets 0 side padding) */
footer.sf .shell{padding-left:48px!important;padding-right:48px!important;}
@media(max-width:900px){footer.sf .shell{padding-left:24px!important;padding-right:24px!important;}}
/* footer email — refined, less oversized */
footer.sf .sf__mid .big{font-size:clamp(26px,4vw,44px)!important;}
/* footer contrast — meet WCAG AA on the dark background (override duplicated per-page rules) */
footer.sf .sf__trust{color:rgba(208,226,242,.92)!important;}
footer.sf .sf__trust b{color:var(--blue-soft)!important;}
footer.sf .sf__base .cr{color:rgba(232,240,248,.74)!important;}
/* footer legal links */
.sf__legal{display:flex;flex-wrap:wrap;gap:8px 22px;justify-content:center;}
.sf__legal a{font-size:10.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(200,222,240,.78);transition:color .4s var(--ease);}
.sf__legal a:hover{color:var(--blue-soft);}
/* shared tokens so standalone pages (legal) render with brand colours */
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--radius:2px;--sans:"Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;}
/* shared chrome (header/nav/base) — so standalone pages (e.g. legal) get a properly styled, working header. Identical values to per-page blocks, so no effect on content pages. */
*{box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;text-rendering:optimizeLegibility;}
.skip-link{position:absolute;left:8px;top:-48px;z-index:2000;background:var(--blue);color:var(--ink);padding:11px 20px;font-weight:700;font-size:13px;letter-spacing:.04em;border-radius:0 0 8px 8px;text-decoration:none;transition:top .2s var(--ease);}
.skip-link:focus{top:0;outline:2px solid var(--cream);outline-offset:2px;}
img{max-width:100%;display:block;}
a{color:inherit;text-decoration:none;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:70;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,0.35));transition:width .12s linear;}
header{position:fixed;top:0;left:0;right:0;z-index:50;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,0.66) 0%,rgba(10,22,40,0.38) 42%,rgba(10,22,40,0.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);-webkit-backdrop-filter:saturate(140%) blur(14px);backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,0.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}
header.scrolled .nav .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}
.menu a{font-size:12.5px;letter-spacing:0.14em;text-transform:uppercase;color:rgba(244,246,248,0.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}
.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);-webkit-backdrop-filter:blur(14px);backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.shell{padding:0 24px;}.burger{display:flex;}.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}}
/* shared footer layout so standalone pages (e.g. legal) get a properly styled footer. Identical values to per-page blocks. */
.sf{position:relative;background:var(--ink);overflow:hidden;}
.sf .shell{position:relative;z-index:2;padding:62px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:50px;width:auto;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
