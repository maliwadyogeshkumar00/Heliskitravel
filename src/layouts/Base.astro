---
// Shared layout: one source of truth for <head>, header and footer across every page.
const { title, description = '', active = '', image, schema, heroImage, ogType = 'website', publishedTime, modifiedTime } = Astro.props;
const LOGO = '/brand/logo.webp';
const pkgActive = active === 'packages';
const SITE = 'https://heliskitravel.com';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = SITE + (path === '/' ? '' : path);
const ogImage = SITE + (image || (heroImage ? `/images/${heroImage}.webp` : '/images/packages-hero.jpg'));
const ogImageType = /\.png$/i.test(ogImage) ? 'image/png' : /\.jpe?g$/i.test(ogImage) ? 'image/jpeg' : 'image/webp';

// ---- Breadcrumbs (auto from path; package detail pages nest under Packages) ----
const LABELS = {
  'packages':'Packages','classic-heliskiing':'Classic Heliskiing','heli-assisted-touring':'Heli-Assisted Touring',
  'private-heliskiing':'Private Heliskiing','travel-here':'Travel Here','siglo-hotel':'Sigló Hotel',
  'iceland':'Iceland','gallery':'Gallery','about':'About Us','contact':'Contact',
  'privacy-policy':'Privacy Policy','terms':'Terms & Conditions','cookie-policy':'Cookie Policy','imprint':'Imprint',
  'field-notes':'Field Notes','heliskiing-guide':'Heliskiing Guide'
};
const PARENT = { 'classic-heliskiing':'packages','heli-assisted-touring':'packages','private-heliskiing':'packages' };
const slug = path.replace(/^\//,'');
const segs = slug ? slug.split('/') : [];
// Human-readable name for a leaf page when it isn't in LABELS (e.g. field-notes articles).
const cleanTitle = (title || '').replace(/\s*[|–—-]\s*Heliski Travel.*$/i,'').replace(/\s*\((?:19|20)\d\d\)\s*$/,'').trim();
const crumbNodes = [];
if (segs.length === 1) {
  const s = segs[0];
  if (PARENT[s]) crumbNodes.push({ name: LABELS[PARENT[s]] || PARENT[s], url: SITE + '/' + PARENT[s] });
  crumbNodes.push({ name: LABELS[s] || cleanTitle || s, url: canonical });
} else if (segs.length > 1) {
  let acc = '';
  segs.forEach((s, i) => {
    acc += (i ? '/' : '') + s;
    const isLast = i === segs.length - 1;
    crumbNodes.push({ name: LABELS[s] || (isLast ? (cleanTitle || s) : s), url: SITE + '/' + acc });
  });
}
const breadcrumbItems = [{ name:'Home', url:SITE + '/' }].concat(crumbNodes);
const breadcrumbLd = slug ? {
  "@type":"BreadcrumbList",
  "@id": canonical + "#breadcrumb",
  "itemListElement": breadcrumbItems.map((it, i) => ({
    "@type":"ListItem","position": i+1, "name": it.name, "item": it.url
  }))
} : null;

// ---- Core entity graph (LocalBusiness/TravelAgency + WebSite + WebPage) ----
const orgLd = {
  "@type":"TravelAgency",
  "@id": SITE + "/#org",
  "name":"Heliski Travel",
  "url": SITE,
  "logo": { "@type":"ImageObject", "url": SITE + "/logo-google.png", "width":600, "height":600 },
  "image": ogImage,
  "sameAs": ["https://www.instagram.com/heliskitravel"],
  "founder": { "@id": SITE + "/#vegard" },
  "knowsLanguage": ["en","no"],
  "email":"info@heliskitravel.com",
  "telephone":"+41797030917",
  "priceRange":"€€€€",
  "description":"Authorised booking agent for Viking Heliskiing in Siglufjörður, North Iceland — 3, 4 and 5-day heliskiing weeks with IFMGA-certified guides, based at the 4-star Sigló Hótel.",
  "areaServed":{ "@type":"Place","name":"Troll Peninsula, North Iceland","geo":{ "@type":"GeoCoordinates","latitude":66.1516,"longitude":-18.9075 } },
  "knowsAbout":["Heliskiing","Off-piste skiing","Ski touring","Troll Peninsula","Siglufjörður","Viking Heliskiing","Iceland ski holidays","Sigló Hótel"],
  "contactPoint":[{ "@type":"ContactPoint","contactType":"reservations","email":"info@heliskitravel.com","telephone":"+41797030917","availableLanguage":["en"] }],
  "makesOffer":[
    { "@type":"Offer","itemOffered":{ "@type":"TouristTrip","name":"Classic Heliskiing Week — Troll Peninsula, Iceland" },"priceCurrency":"EUR","price":"6790","priceSpecification":{ "@type":"PriceSpecification","minPrice":"6790","maxPrice":"10490","priceCurrency":"EUR" },"url": SITE + "/classic-heliskiing" },
    { "@type":"Offer","itemOffered":{ "@type":"TouristTrip","name":"Private Heliskiing — Iceland" },"url": SITE + "/private-heliskiing" },
    { "@type":"Offer","itemOffered":{ "@type":"TouristTrip","name":"Heli-Assisted Touring — Iceland" },"url": SITE + "/heli-assisted-touring" }
  ]
};
// Founder as a first-class, site-wide entity (resolves #vegard on every page for the knowledge graph / E-E-A-T).
const personLd = {
  "@type":"Person",
  "@id": SITE + "/#vegard",
  "name":"Vegard Knudsen",
  "jobTitle":"Founder & Heliski Travel Specialist",
  "worksFor": { "@id": SITE + "/#org" },
  "url": SITE + "/about",
  "image": SITE + "/brand/vegard-portrait.webp",
  "nationality":"Norwegian",
  "knowsAbout":["Heliskiing","Off-piste skiing","Ski touring","Troll Peninsula","Iceland ski holidays","Viking Heliskiing"]
};
const websiteLd = { "@type":"WebSite", "@id": SITE + "/#website", "url": SITE, "name":"Heliski Travel", "publisher": { "@id": SITE + "/#org" }, "inLanguage":"en-GB" };
const webpageLd = { "@type":"WebPage", "@id": canonical + "#webpage", "url": canonical, "name": title, "isPartOf": { "@id": SITE + "/#website" }, "about": { "@id": SITE + "/#org" }, "primaryImageOfPage": { "@type":"ImageObject", "url": ogImage }, "inLanguage":"en-GB", "speakable": { "@type":"SpeakableSpecification", "cssSelector":["h1",".gd-lede",".intro",".lede"] }, ...(description ? { "description": description } : {}), ...(slug ? { "breadcrumb": { "@id": canonical + "#breadcrumb" } } : {}) };
const graph = [orgLd, personLd, websiteLd, webpageLd];
if (breadcrumbLd) graph.push(breadcrumbLd);
if (Array.isArray(schema)) graph.push(...schema);
else if (schema) graph.push(schema);
const jsonLd = { "@context":"https://schema.org", "@graph": graph };
const FAVICON = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='7' fill='%230A1628'/%3E%3Cpath d='M5 24 L13 11 L18 19 L21 15 L27 24 Z' fill='%23A8CFE0'/%3E%3Ccircle cx='23' cy='9' r='2' fill='%23C3DCEE'/%3E%3C/svg%3E";
---
<!DOCTYPE html>
<html lang="en">
<head>
<!-- Google Tag Manager -->
<script>(function(w,d){w.dataLayer=w.dataLayer||[];var loaded=false;function load(){if(loaded)return;loaded=true;w.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName('script')[0],j=d.createElement('script');j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id=GTM-5BXSZM97';f.parentNode.insertBefore(j,f);}var ev=['scroll','pointerdown','keydown','touchstart','mousemove'];function t(){load();ev.forEach(function(e){w.removeEventListener(e,t);});}ev.forEach(function(e){w.addEventListener(e,t,{once:true,passive:true});});setTimeout(load,3500);})(window,document);</script>
<!-- End Google Tag Manager -->
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  {/* LCP hero preload FIRST — before title/meta so the preload scanner starts the hero fetch immediately. Responsive: tiny 768w on mobile, full on desktop. */}
  {heroImage && (
    <>
      <link rel="preload" as="image" href={`/images/${heroImage}-768.webp`} media="(max-width: 767px)" fetchpriority="high" />
      <link rel="preload" as="image" href={`/images/${heroImage}.webp`} media="(min-width: 768px)" fetchpriority="high" />
    </>
  )}
  {/* homepage hero poster is inlined as the LCP image — no network preload needed */}
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="canonical" href={canonical} />
  <link rel="alternate" hreflang="en" href={canonical} />
  <link rel="alternate" hreflang="x-default" href={canonical} />
  <meta name="author" content="Heliski Travel" />
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#0A1628" />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="geo.region" content="IS-6" />
  <meta name="geo.placename" content="Siglufjörður, Troll Peninsula, North Iceland" />
  <meta name="geo.position" content="66.1516;-18.9075" />
  <meta name="ICBM" content="66.1516, -18.9075" />
  <link rel="alternate" type="text/plain" href="/llms.txt" title="LLM-readable site summary" />
  <link rel="alternate" type="application/rss+xml" title="Heliski Travel — Field Notes" href="/rss.xml" />
  <link rel="preconnect" href="https://www.googletagmanager.com" />
  <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
  <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
  <link rel="dns-prefetch" href="https://www.google-analytics.com" />
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Heliski Travel" />
  <meta property="og:locale" content="en_GB" />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:secure_url" content={ogImage} />
  <meta property="og:image:type" content={ogImageType} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="800" />
  <meta property="og:image:alt" content={title} />
  {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {ogType === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
  {ogType === 'article' && <meta property="article:author" content="Vegard Knudsen" />}
  {ogType === 'article' && <meta property="article:publisher" content="https://heliskitravel.com" />}
  {ogType === 'article' && <meta property="article:section" content="Field Notes" />}
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  {description && <meta name="twitter:description" content={description} />}
  <meta name="twitter:image" content={ogImage} />
  <meta name="twitter:image:alt" content={title} />
  <!-- Self-hosted fonts (in-house — no render-blocking external CSS). Preload only the above-the-fold weights. -->
  <link rel="preload" href="/fonts/mulish-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/cormorant-500-italic.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face{font-family:'Mulish';font-style:normal;font-weight:300;font-display:swap;src:url('/fonts/mulish-300.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/mulish-400.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/mulish-500.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:600;font-display:swap;src:url('/fonts/mulish-600.woff2') format('woff2');}
    @font-face{font-family:'Mulish';font-style:normal;font-weight:700;font-display:swap;src:url('/fonts/mulish-700.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:400;font-display:swap;src:url('/fonts/cormorant-400.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:normal;font-weight:500;font-display:swap;src:url('/fonts/cormorant-500.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:400;font-display:swap;src:url('/fonts/cormorant-400-italic.woff2') format('woff2');}
    @font-face{font-family:'Cormorant Garamond';font-style:italic;font-weight:500;font-display:swap;src:url('/fonts/cormorant-500-italic.woff2') format('woff2');}
  </style>
  {/* Fonts are fully self-hosted (Mulish + Cormorant Garamond) — no external font CSS, no third-party
      DNS/TLS on the critical path, and no Content-Security-Policy exceptions needed. */}
  {/* Prefetch the most likely next routes from the homepage — makes onward nav feel instant */}
  {path === '/' && (
    <>
      <link rel="prefetch" href="/packages" />
      <link rel="prefetch" href="/iceland" />
      <link rel="prefetch" href="/siglo-hotel" />
    </>
  )}
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-5BXSZM97" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
