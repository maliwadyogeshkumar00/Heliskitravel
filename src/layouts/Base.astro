<script is:inline>
(function(){
  var m=document.getElementById('pkgm');if(!m)return;
  var scope=m.querySelector('.pkgm__main')||m;
  function setDays(d,v,w){scope.querySelectorAll('[data-count]').forEach(function(e){e.textContent=d;});scope.querySelectorAll('[data-vert]').forEach(function(e){e.textContent=v;});if(w){scope.querySelectorAll('[data-dayword]').forEach(function(e){e.textContent=w;});}}
  function open(){m.classList.add('open');m.setAttribute('aria-hidden','false');document.body.classList.add('pkgm-open');var h=m.querySelector('.pkgm__head');var pn=m.querySelector('.pkgm__panel');if(h&&pn){pn.style.setProperty('--ph',h.offsetHeight+'px');}}
  function close(){m.classList.remove('open');m.setAttribute('aria-hidden','true');document.body.classList.remove('pkgm-open');}
  m.querySelectorAll('[data-pkgmodal-close]').forEach(function(b){b.addEventListener('click',close);});
  m.addEventListener('click',function(e){if(e.target===m)close();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('open'))close();});
  var weeks=[].slice.call(m.querySelectorAll('.wk'));
  function selectWeek(w){if(!w)return;weeks.forEach(function(x){x.classList.remove('active');});w.classList.add('active');setDays(w.dataset.days,w.dataset.vert,w.dataset.word);}
  weeks.forEach(function(w){w.addEventListener('click',function(){selectWeek(w);});});
  document.querySelectorAll('[data-pkgmodal-open]').forEach(function(b){b.addEventListener('click',function(){var wk=b.getAttribute('data-week');if(wk){selectWeek(weeks.filter(function(x){return x.dataset.days===wk;})[0]);}open();});});
  /* reader-controlled text size (A- / A+) */
  var main=m.querySelector('.pkgm__main'), rail=m.querySelector('.pkgm__rail');
  if(main&&rail){
    var MIN=1, MAX=1.6, STEP=0.1, fs=1;
    try{var sv=parseFloat(localStorage.getItem('pkgmFs'));if(sv>=MIN&&sv<=MAX)fs=sv;}catch(e){}
    var wrap=document.createElement('div');wrap.className='pkgm__fs';
    wrap.innerHTML='<span class="lbl">Text size</span><span class="row"><button type="button" class="am" aria-label="Decrease text size">A&minus;</button><span class="cur" aria-live="polite"></span><button type="button" class="ap" aria-label="Increase text size">A+</button></span>';
    rail.appendChild(wrap);
    var cur=wrap.querySelector('.cur'),bMinus=wrap.querySelector('.am'),bPlus=wrap.querySelector('.ap');
    function apply(){fs=Math.min(MAX,Math.max(MIN,Math.round(fs*100)/100));main.style.setProperty('--fs',fs);cur.textContent=Math.round(fs*100)+'%';bMinus.disabled=fs<=MIN+0.001;bPlus.disabled=fs>=MAX-0.001;try{localStorage.setItem('pkgmFs',String(fs));}catch(e){}}
    bMinus.addEventListener('click',function(){fs-=STEP;apply();});
    bPlus.addEventListener('click',function(){fs+=STEP;apply();});
    apply();
  }
})();
</script>
<script is:inline>
(function(){var s=document.getElementById('fabStack'),h=document.getElementById('fabHide'),show=document.getElementById('fabShow');if(!s||!show)return;
  function setOpen(open){s.classList.toggle('hidden',!open);show.classList.toggle('show',!open);try{sessionStorage.setItem('fabOpen',open?'1':'0');}catch(e){}}
  var opened=false;try{opened=sessionStorage.getItem('fabOpen')==='1';}catch(e){}
  if(opened)setOpen(true); /* default is collapsed (launcher only); open only if user opened it this session */
  show.addEventListener('click',function(){setOpen(true);});
  if(h)h.addEventListener('click',function(){setOpen(false);});})();
</script>
<script is:inline>
/* Sticky reading rail — reading time, progress fill, active-section highlight (article pages only) */
(function(){
  var toc=document.querySelector('.gd-toc'), art=document.querySelector('.gd-art');
  if(!toc||!art) return;
  var hero=document.querySelector('.gd-hero');
  if(hero && !hero.querySelector('.gd-hero__cue')){ var cue=document.createElement('div'); cue.className='gd-hero__cue'; cue.style.cursor='pointer'; cue.setAttribute('aria-hidden','true'); cue.innerHTML='<span></span>'; cue.addEventListener('click',function(){ window.scrollTo({top:Math.round(window.innerHeight*0.92),behavior:'smooth'}); }); hero.appendChild(cue); }
  var words=((art.innerText||'').trim().match(/\S+/g)||[]).length, mins=Math.max(1,Math.round(words/220));
  var meta=document.createElement('p'); meta.className='gd-toc__meta'; meta.textContent='≈ '+mins+' min read';
  var track=document.createElement('div'); track.className='gd-toc__track';
  var prog=document.createElement('span'); prog.className='gd-toc__prog'; track.appendChild(prog);
  var label=toc.querySelector('.gd-toc__t');
  if(label){ label.insertAdjacentElement('afterend',track); label.insertAdjacentElement('afterend',meta); }
  else { toc.insertBefore(track,toc.firstChild); toc.insertBefore(meta,toc.firstChild); }
  var links=[].slice.call(toc.querySelectorAll('a[href^="#"]'));
  var heads=links.map(function(a){return document.getElementById(a.getAttribute('href').slice(1));}).filter(Boolean);
  function onScroll(){
    var vh=window.innerHeight, top=art.getBoundingClientRect().top;
    var total=Math.max(1,art.offsetHeight - vh*0.6), done=Math.min(Math.max(-top + vh*0.3,0),total);
    prog.style.width=(done/total*100).toFixed(1)+'%';
  }
  window.addEventListener('scroll',onScroll,{passive:true}); window.addEventListener('resize',onScroll,{passive:true}); onScroll();
  if('IntersectionObserver' in window){
    var io=new IntersectionObserver(function(es){
      es.forEach(function(en){ if(en.isIntersecting){ var id=en.target.id;
        links.forEach(function(a){ a.classList.toggle('is-active', a.getAttribute('href')==='#'+id); }); } });
    },{rootMargin:'-12% 0px -70% 0px',threshold:0});
    heads.forEach(function(h){ io.observe(h); });
  }
})();
</script>
</body>
