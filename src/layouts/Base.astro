  m.querySelectorAll('[data-pkgmodal-close]').forEach(function(b){b.addEventListener('click',close);});
  m.addEventListener('click',function(e){if(e.target===m)close();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('open'))close();});
  var weeks=[].slice.call(m.querySelectorAll('.wk'));
  function selectWeek(w){if(!w)return;weeks.forEach(function(x){x.classList.remove('active');});w.classList.add('active');setDays(w.dataset.days,w.dataset.vert,w.dataset.word);}
  weeks.forEach(function(w){w.addEventListener('click',function(){selectWeek(w);});});
  document.querySelectorAll('[data-pkgmodal-open]').forEach(function(b){b.addEventListener('click',function(){var wk=b.getAttribute('data-week');if(wk){selectWeek(weeks.filter(function(x){return x.dataset.days===wk;})[0]);}open();});});
})();
</script>
<script is:inline>
(function(){var s=document.getElementById('fabStack'),h=document.getElementById('fabHide'),show=document.getElementById('fabShow');if(!s||!show)return;
  function setOpen(open){s.classList.toggle('hidden',!open);show.classList.toggle('show',!open);try{sessionStorage.setItem('fabOpen',open?'1':'0');}catch(e){}}
  var opened=false;try{opened=sessionStorage.getItem('fabOpen')==='1';}catch(e){}
  if(opened)setOpen(true); /* default is collapsed (launcher only); open only if user opened it this session */
  show.addEventListener('click',function(){setOpen(true);});
  if(h)h.addEventListener('click',function(){setOpen(false);});})();
</script>
</body>
</html>
