---
// Shared layout: one source of truth for <head>, header and footer across every page.
const { title, description = '', active = '' } = Astro.props;
const LOGO = 'https://heliskitravel.com/wp-content/uploads/2026/05/Heliski-Updated-Logo.webp';
const pkgActive = active === 'packages';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <link rel="stylesheet" href="https://use.typekit.net/ncf8pad.css" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;1,400;1,500&family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>
<div class="progress" id="progress" aria-hidden="true"></div>

<header id="siteHeader"><div class="shell nav">
  <a class="logo" href="/" aria-label="Heliski Travel home"><img src={LOGO} alt="Heliski Travel" width="220" height="108" /></a>
  <button class="burger" id="burger" aria-label="Open menu" aria-controls="menu" aria-expanded="false"><span></span><span></span><span></span></button>
  <nav class="menu" id="menu" aria-label="Primary">
    <span class="hassub"><a href="/packages" class={pkgActive ? 'active' : undefined}>Packages<span class="caret">▾</span></a><div class="submenu"><a href="/classic-heliskiing">Classic Heliskiing</a><a href="/heli-assisted-touring">Heli-Assisted Touring</a><a href="/private-heliskiing">Private Heliskiing</a></div></span>
    <a href="/travel-here" class={active === 'travel' ? 'active' : undefined}>Travel Here</a>
    <a href="/siglo-hotel" class={active === 'siglo' ? 'active' : undefined}>Sigló Hotel</a>
    <a href="/iceland" class={active === 'iceland' ? 'active' : undefined}>Iceland</a>
    <a href="/about" class={active === 'about' ? 'active' : undefined}>About Us</a>
    <a href="/contact" class={active === 'contact' ? 'active' : undefined}>Contact</a>
  </nav>
</div></header>

<slot />

<footer class="sf"><div class="shell">
  <div class="sf__top"><a class="logo" href="/" aria-label="Heliski Travel home"><img src={LOGO} alt="Heliski Travel" width="200" height="98" loading="lazy" /></a>
    <nav class="sf__nav" aria-label="Footer"><a href="/packages">Packages</a><a href="/travel-here">Travel Here</a><a href="/siglo-hotel">Sigló Hotel</a><a href="/iceland">Iceland</a><a href="/contact">Contact</a></nav></div>
  <div class="sf__mid"><a class="big" href="mailto:hello@heliskitravel.com">hello@heliskitravel.com</a><div class="sf__trust">Authorised Agent · Viking Heliskiing Iceland · Certified Guides · <b>Reply within 12 hours</b></div></div>
  <div class="sf__base"><span class="cr">© 2026 Heliski Travel. All Rights Reserved.</span><a href="#siteHeader">Back to top ↑</a></div>
</div></footer>

<!-- Gallery lightbox (shared) -->
<div class="lb" id="lb" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Image viewer">
  <button class="lb__x" id="lbX" type="button" aria-label="Close">&times;</button>
  <button class="lb__nav lb__prev" id="lbPrev" type="button" aria-label="Previous image">&#8249;</button>
  <img class="lb__img" id="lbImg" alt="" />
  <button class="lb__nav lb__next" id="lbNext" type="button" aria-label="Next image">&#8250;</button>
  <div class="lb__count" id="lbCount" aria-hidden="true"></div>
</div>
<style is:global>
.lb{position:fixed;inset:0;z-index:200;display:none;align-items:center;justify-content:center;background:rgba(8,16,28,.93);-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px);opacity:0;transition:opacity .35s cubic-bezier(.16,1,.3,1);}
.lb.open{display:flex;opacity:1;}
.lb__img{max-width:92vw;max-height:86vh;border-radius:4px;box-shadow:0 40px 90px rgba(0,0,0,.6);user-select:none;}
.lb__x,.lb__nav{position:absolute;border:0;background:rgba(244,246,248,.1);color:#F4F6F8;cursor:pointer;border-radius:50%;display:flex;align-items:center;justify-content:center;transition:background .3s,transform .3s;}
.lb__x{top:22px;right:26px;width:46px;height:46px;font-size:24px;line-height:1;}
.lb__nav{top:50%;transform:translateY(-50%);width:54px;height:54px;font-size:30px;line-height:1;}
.lb__prev{left:24px;}.lb__next{right:24px;}
.lb__x:hover{background:rgba(168,207,224,.3);}
.lb__nav:hover{background:rgba(168,207,224,.3);}
.lb__count{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);font-size:12px;letter-spacing:.2em;color:rgba(195,220,238,.7);}
@media(max-width:700px){.lb__nav{width:44px;height:44px;font-size:24px;}.lb__prev{left:8px;}.lb__next{right:8px;}.lb__x{top:12px;right:12px;}.lb__img{max-width:96vw;}}
</style>
<script is:inline>
(function(){
  var lb=document.getElementById('lb'),img=document.getElementById('lbImg'),cnt=document.getElementById('lbCount');
  if(!lb)return;
  var links=[].slice.call(document.querySelectorAll('.gal a[href]'));
  if(!links.length)return;
  var srcs=links.map(function(a){return a.getAttribute('href');});
  var i=0;
  function show(n){i=(n+srcs.length)%srcs.length;img.src=srcs[i];cnt.textContent=(i+1)+' / '+srcs.length;}
  function open(n){show(n);lb.classList.add('open');lb.setAttribute('aria-hidden','false');document.body.style.overflow='hidden';}
  function close(){lb.classList.remove('open');lb.setAttribute('aria-hidden','true');document.body.style.overflow='';setTimeout(function(){img.src='';},350);}
  links.forEach(function(a,n){a.addEventListener('click',function(e){e.preventDefault();open(n);});});
  document.getElementById('lbX').addEventListener('click',close);
  document.getElementById('lbPrev').addEventListener('click',function(e){e.stopPropagation();show(i-1);});
  document.getElementById('lbNext').addEventListener('click',function(e){e.stopPropagation();show(i+1);});
  lb.addEventListener('click',function(e){if(e.target===lb)close();});
  document.addEventListener('keydown',function(e){if(!lb.classList.contains('open'))return;if(e.key==='Escape')close();else if(e.key==='ArrowLeft')show(i-1);else if(e.key==='ArrowRight')show(i+1);});
})();
</script>

<!-- Package detail modal (shared styling + behaviour; markup lives per-page) -->
<style is:global>
.pkgmore{display:inline-flex;align-items:center;gap:12px;background:none;border:0;color:var(--blue-soft);font-family:var(--sans);font-size:12.5px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;cursor:pointer;padding:10px 0;}
.pkgmore .arw{transition:transform .4s var(--ease);}
.pkgmore:hover .arw{transform:translateX(5px);}
.pkgm{position:fixed;inset:0;z-index:210;display:none;align-items:center;justify-content:center;padding:24px;background:rgba(8,16,28,.74);-webkit-backdrop-filter:blur(9px);backdrop-filter:blur(9px);opacity:0;transition:opacity .4s var(--ease);}
.pkgm.open{display:flex;opacity:1;}
.pkgm__panel{position:relative;width:min(1080px,100%);max-height:90vh;overflow:auto;background:linear-gradient(180deg,rgba(18,34,52,.97),rgba(11,22,38,.99));border:1px solid rgba(138,180,204,.28);border-radius:14px;box-shadow:0 50px 120px rgba(0,0,0,.6);transform:translateY(20px) scale(.98);transition:transform .5s var(--ease);}
.pkgm.open .pkgm__panel{transform:none;}
.pkgm__head{display:flex;justify-content:space-between;align-items:flex-start;gap:24px;padding:38px 44px 26px;border-bottom:1px solid var(--line);}
.pkgm__head .eyebrow{display:inline-flex;align-items:center;gap:12px;font-size:11px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.pkgm__head h2{margin:14px 0 0;font-family:var(--sans);font-weight:600;font-size:clamp(28px,3vw,40px);line-height:1.02;color:var(--cream);letter-spacing:-.01em;}
.pkgm__head h2 .s{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}
.pkgm__x{flex:none;width:46px;height:46px;border-radius:50%;border:1px solid rgba(138,180,204,.3);background:transparent;color:var(--cream);font-size:22px;line-height:1;cursor:pointer;transition:background .3s;}
.pkgm__x:hover{background:rgba(168,207,224,.18);}
.pkgm__body{display:grid;grid-template-columns:308px 1fr;}
.pkgm__rail{padding:34px 36px;border-right:1px solid var(--line);}
.pkgm__rail .eyebrow{font-size:11px;font-weight:600;letter-spacing:.24em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.pkgm__weeks{display:flex;flex-direction:column;gap:12px;margin:18px 0 24px;}
.wk{position:relative;text-align:left;background:rgba(138,180,204,.06);border:1px solid var(--line);border-radius:10px;padding:15px 17px;cursor:pointer;transition:background .35s,border-color .35s;font-family:var(--sans);}
.wk:hover{background:rgba(138,180,204,.12);}
.wk.active{background:rgba(168,207,224,.16);border-color:rgba(168,207,224,.5);}
.wk__d{display:block;font-size:16px;font-weight:600;color:var(--cream);}
.wk__v{display:block;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:var(--blue-soft);margin-top:3px;}
.wk__p{display:block;font-size:12.5px;color:rgba(244,246,248,.6);margin-top:6px;}
.wk__pop{display:inline-block;margin-top:9px;font-size:9px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--ink);background:var(--blue);padding:4px 9px;border-radius:3px;}
.pkgm__cta{width:100%;justify-content:center;}
.pkgm__main{padding:34px 44px;}
.pkgm__main h3{margin:0 0 18px;font-family:var(--sans);font-weight:600;font-size:23px;color:var(--cream);}
.pkgm__main .pkgm__h2{margin:32px 0 14px;font-size:clamp(21px,2.3vw,28px);letter-spacing:-.01em;}
.pkgm__incl{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:13px 30px;}
.pkgm__incl li{position:relative;padding-left:20px;font-size:14.5px;line-height:1.5;color:rgba(244,246,248,.82);}
.pkgm__incl li::before{content:"";position:absolute;left:0;top:8px;width:7px;height:7px;border-radius:50%;background:var(--blue);}
.pkgm__incl b{color:var(--cream);font-weight:700;}
.pkgm__main p{font-size:15px;line-height:1.75;color:rgba(244,246,248,.7);margin:0 0 14px;max-width:62ch;}
body.pkgm-open{overflow:hidden;}
@media(max-width:820px){.pkgm__body{grid-template-columns:1fr;}.pkgm__rail{border-right:0;border-bottom:1px solid var(--line);}.pkgm__incl{grid-template-columns:1fr;}.pkgm__head{padding:26px 22px 18px;}.pkgm__main,.pkgm__rail{padding:24px 22px;}}
</style>
<script is:inline>
(function(){
  var m=document.getElementById('pkgm');if(!m)return;
  function setDays(d,v){m.querySelectorAll('[data-count]').forEach(function(e){e.textContent=d;});m.querySelectorAll('[data-vert]').forEach(function(e){e.textContent=v;});}
  function open(){m.classList.add('open');m.setAttribute('aria-hidden','false');document.body.classList.add('pkgm-open');}
  function close(){m.classList.remove('open');m.setAttribute('aria-hidden','true');document.body.classList.remove('pkgm-open');}
  document.querySelectorAll('[data-pkgmodal-open]').forEach(function(b){b.addEventListener('click',open);});
  m.querySelectorAll('[data-pkgmodal-close]').forEach(function(b){b.addEventListener('click',close);});
  m.addEventListener('click',function(e){if(e.target===m)close();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&m.classList.contains('open'))close();});
  var weeks=[].slice.call(m.querySelectorAll('.wk'));
  weeks.forEach(function(w){w.addEventListener('click',function(){weeks.forEach(function(x){x.classList.remove('active');});w.classList.add('active');setDays(w.dataset.days,w.dataset.vert);});});
})();
</script>
</body>
</html>
