---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found | Heliski Travel" description="This page could not be found. Return home to explore Iceland heliskiing with Heliski Travel.">
<section class="band band--ink nf">
  <div class="shell nf__in">
    <p class="nf__k">Error 404</p>
    <h1 class="nf__h">This run doesn't exist.</h1>
    <p class="nf__sub">The page you're looking for has drifted off-piste. Let's get you back to safe terrain.</p>
    <div class="nf__cta">
      <a class="btn" href="/"><span>Back to home</span> <span class="arw">&rarr;</span></a>
      <a class="btn btn--ghost" href="/packages"><span>View packages</span></a>
    </div>
    <nav class="nf__links" aria-label="Popular pages">
      <a href="/iceland">Iceland Guide</a>
      <a href="/siglo-hotel">Sigl&oacute; Hotel</a>
      <a href="/gallery">Gallery</a>
      <a href="/contact">Contact</a>
    </nav>
  </div>
</section>
<style is:global>
.nf{min-height:78vh;display:flex;align-items:center;}
.nf__in{max-width:720px;text-align:center;margin:0 auto;padding:80px 0;}
.nf__k{font-size:12px;letter-spacing:.22em;text-transform:uppercase;color:var(--blue);margin:0 0 18px;}
.nf__h{font-family:var(--serif);font-weight:500;font-size:clamp(38px,6vw,64px);line-height:1.02;letter-spacing:-.01em;color:var(--cream);margin:0 0 20px;}
.nf__sub{color:rgba(244,246,248,0.66);font-size:17px;line-height:1.7;margin:0 auto 40px;max-width:48ch;}
.nf__cta{display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-bottom:52px;}
.nf__links{display:flex;gap:28px;justify-content:center;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:30px;}
.nf__links a{color:var(--blue-soft);font-size:13px;letter-spacing:.05em;text-decoration:none;transition:color .3s var(--ease);}
.nf__links a:hover{color:var(--cream);}
.btn--ghost{background:none;border:1px solid var(--cta-line);}
</style>
</Base>
