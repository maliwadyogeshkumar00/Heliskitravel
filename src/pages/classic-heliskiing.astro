---
import Base from '../layouts/Base.astro';
const body = `

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__photo" id="heroPhoto"></div>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" href="#" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell"><h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Classic Heliskiing — Iceland</h1></div>
</section>

<!-- INTRO + PRICING -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Full Helicopter Week</p>
      <h2 class="sectit">Powder, corn,<span class="s">and exposed Arctic lines.</span></h2>
      <p class="intro">The full helicopter week. Powder, stable spring corn, exposed lines you only find in the Arctic. Up to 1,500 m of vertical drop in a single run, and a normal day in the 18,000–25,000 ft range. The mountain sets the limit, not the program.</p>
    </div>
    <div class="tiers">
      <div class="tier feat reveal"><span class="badge">Most popular</span><p class="dur">Three days</p><div class="price">€6,790</div><p class="per">twin per guest</p>
        <dl><div><dt>Vertical</dt><dd>45,000 ft</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Full board</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + guide</dd></div></dl>
        <a class="btn btn--solid" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
      <div class="tier reveal"><p class="dur">Four days</p><div class="price">€8,890</div><p class="per">twin per guest</p>
        <dl><div><dt>Vertical</dt><dd>60,000 ft</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Full board</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + guide</dd></div></dl>
        <a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
      <div class="tier reveal"><p class="dur">Five days</p><div class="price">€10,490</div><p class="per">twin per guest</p>
        <dl><div><dt>Vertical</dt><dd>75,000 ft</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Full board</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + guide</dd></div></dl>
        <a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
    </div>
  </div>
</section>

<!-- MORE THAN -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Also in every week</p>
      <h2 class="sectit">More than <span class="s">the descents.</span></h2>
      <p class="intro">The week is more than the runs — Sigló at sunset, hot tubs and communal dinners, K2 gear, and a proper picnic on the mountain.</p>
    </div>
    <div class="features reveal">
      <div class="feature"><h4>Field lunch</h4><p>Fresh-cut sandwiches and dessert wine, on the mountain between runs.</p></div>
      <div class="feature"><h4>Yoga &amp; stretches</h4><p>Optional morning stretches every day — recommended after a helicopter day.</p></div>
      <div class="feature"><h4>Helicopter groups</h4><p>Up to 3 rotating groups, a maximum of 12 guests.</p></div>
      <div class="feature"><h4>Equipment</h4><p>K2 freeride skis with Marker bindings, K2 poles and K2 snowboards.</p></div>
      <div class="feature"><h4>Après-ski</h4><p>Hot tubs at sunset, communal dinners, and the bar at Sigló.</p></div>
      <div class="feature"><h4>Season</h4><p>March 10 to June 6 — ten weeks of stable Arctic light.</p></div>
    </div>
    <p class="note reveal"><b style="color:var(--blue-soft);font-weight:600;">Not included:</b> International &amp; domestic flights · Travel &amp; cancellation insurance · Adventure activities other than heliskiing · Credit card fees.</p>
  </div>
</section>

<!-- INCLUDED + PURE -->
<section class="band band--ink">
  <div class="shell split2">
    <div class="reveal">
      <p class="eyebrow">What's included</p>
      <h2 class="sectit" style="font-size:clamp(28px,3.4vw,40px);margin-bottom:30px;">Everything but <span class="s">the flights home.</span></h2>
      <ul class="incl">
        <li>Nights at Sigló Hotel (4-star, ocean-front)</li>
        <li>Nightly three-course dinners at Sigló Restaurant</li>
        <li>Daily breakfast buffet at Sigló Hotel</li>
        <li>Daily lunches at the K2 Club House</li>
        <li>45,000–75,000 ft of vertical, by package length</li>
        <li>Full ski equipment — skis, boots, poles</li>
        <li>BCA avalanche kit — transceiver, shovel, probe, airbag</li>
        <li>Ski shuttle to the clubhouse, 5 minutes away</li>
        <li>Outdoor hot tub &amp; sauna — unlimited access</li>
        <li>Daily yoga &amp; morning stretches</li>
      </ul>
    </div>
    <div class="daybody reveal">
      <p class="eyebrow">Pure heliskiing</p>
      <p style="margin-top:24px;">No skins, no climbing, no earning your turns — just the helicopter, your guide, and run after run of untracked Arctic powder. The moment you reach the bottom, the helicopter is already there to lift you back to the top.</p>
      <p>The Troll Peninsula is one of the last great untouched ski frontiers on earth, where the mountains rise straight out of the sea. You ski from summits to the shoreline of the North Atlantic — no lift lines, no crowds, often no tracks but your own. Ski beneath the midnight sun in spring, or chase the Northern Lights in early season, guided every run by IFMGA-certified guides who have skied this peninsula their whole lives.</p>
      <p class="pull">Your day is measured in vertical feet, not runs — around 15,000 ft a day, our record 19 runs in one. The only thing limiting your day is your legs.</p>
    </div>
  </div>
</section>

<!-- TYPICAL DAY -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">A typical day</p>
      <h2 class="sectit">A typical <span class="s">heliskiing day.</span></h2>
    </div>
    <div class="tl reveal">
      <div class="tlrow"><div class="t">07:00</div><p>A hearty breakfast at the hotel to fuel up for the day.</p></div>
      <div class="tlrow"><div class="t">08:30</div><p>A three-minute drive to the Clubhouse, where your skis or snowboard wait. Guides review the day's plan — terrain, weather, who skis with whom.</p></div>
      <div class="tlrow"><div class="t">09:45</div><p>Helicopters lift off for a full day of skiing.</p></div>
      <div class="tlrow"><div class="t">12:30</div><p>Lunch with a view — fresh-cut sandwiches and Icelandic dessert wine, served on the mountain.</p></div>
      <div class="tlrow"><div class="t">15:00</div><p>Back to the Clubhouse for après — food and drinks, or the hot tubs, bar, kayaking and local brewery before dinner.</p></div>
      <div class="tlrow"><div class="t">20:00</div><p>A three-course, locally sourced dinner — cod, salmon, lamb — then drinks around the fireplace.</p></div>
    </div>
    <p class="note reveal">Sample itinerary · times and schedule vary with weather conditions.</p>
  </div>
</section>

<!-- GALLERY -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Gallery</p>
      <h2 class="sectit">A week <span class="s">in pictures.</span></h2>
    </div>
    <div class="gal reveal">
      <a class="wide" href="https://heliskitravel.com/wp-content/uploads/2026/05/JRJ06349.webp" target="_blank" rel="noopener"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/JRJ06349-1024x683.webp" alt="Heliskiing in Iceland" loading="lazy"/></a>
      <a href="https://heliskitravel.com/wp-content/uploads/2026/05/heli_-6-scaled.webp" target="_blank" rel="noopener"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/heli_-6-1024x580.webp" alt="Helicopter on the mountain" loading="lazy"/></a>
      <a href="https://heliskitravel.com/wp-content/uploads/2026/05/DJI_0806.webp" target="_blank" rel="noopener"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/DJI_0806-1024x767.webp" alt="Aerial of the Troll Peninsula" loading="lazy"/></a>
      <a href="https://heliskitravel.com/wp-content/uploads/2026/05/BRC07196.webp" target="_blank" rel="noopener"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/BRC07196-1024x683.webp" alt="Skier in Arctic powder" loading="lazy"/></a>
      <a class="wide" href="https://heliskitravel.com/wp-content/uploads/2026/05/DSCF1558.jpg" target="_blank" rel="noopener"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/DSCF1558-1024x683.jpg" alt="Siglufjörður fjord" loading="lazy"/></a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="shell">
    <p class="eyebrow">Classic programme · North Iceland</p>
    <h2>When the conditions hold, <span class="s">the mountain sets the limit.</span></h2>
    <div><a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
  </div>
</section>

<!-- FOOTER -->
`;
---
<Base title="Classic Heliskiing Iceland: 3-5 Day Group Week | Heliski Travel" description="Classic Heliskiing in Iceland: 3, 4 or 5-day group week with 4 skiers + guide, 45,000ft per week, Sigló Hotel, IFMGA guides. From €6,790." active="packages">
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"proxima-nova","Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/classic-hero.jpg");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--sans);font-weight:600;letter-spacing:-.015em;font-size:clamp(34px,5vw,60px);line-height:1.02;color:var(--cream);margin:22px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.04em;line-height:1;letter-spacing:0;}
.intro{margin:26px 0 0;color:rgba(244,246,248,.68);font-size:17px;line-height:1.82;max-width:64ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}.submenu{position:static;opacity:1;visibility:visible;transform:none;background:none;border:0;box-shadow:none;padding:4px 0 2px 16px;margin:0;min-width:0;}.submenu::before{display:none;}.submenu a{padding:10px 0;font-size:15px;text-transform:none;letter-spacing:.04em;color:rgba(244,246,248,.7);}}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}

.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding:0 0 100px;overflow:hidden;background:var(--navy);}
.hero__photo{position:absolute;inset:-3%;z-index:0;background:var(--hero) center 38%/cover no-repeat;opacity:0;transform:scale(1.08);transition:opacity 1.8s var(--ease),transform 2.4s var(--ease);}
.hero.ready .hero__photo{opacity:1;transform:scale(1);}
.hero .grade{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(180deg,rgba(10,22,40,0.34) 0%,rgba(10,22,40,0) 22%),linear-gradient(90deg,rgba(10,22,40,0.16) 0%,rgba(10,22,40,0) 52%);}
.hero .shell{position:relative;z-index:3;}
.scrolldn{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;opacity:0;transition:opacity 1s var(--ease) 1.4s;}
.hero.ready .scrolldn{opacity:1;}
.scrolldn span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:scrolldn 1.9s var(--ease) infinite;}
@keyframes scrolldn{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}
.hero .eyebrow{margin-bottom:26px;opacity:0;transform:translateY(12px);transition:opacity 1s var(--ease) .5s,transform 1s var(--ease) .5s;}
.hero .big{margin:0;font-family:var(--sans);font-weight:600;letter-spacing:-.02em;font-size:clamp(32px,3.8vw,56px);line-height:.92;color:var(--cream);opacity:0;transform:translateY(20px);transition:opacity 1.2s var(--ease) .72s,transform 1.2s var(--ease) .72s;}
.hero .big .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;letter-spacing:0;color:var(--blue-soft);}
.hero.ready .eyebrow{opacity:1;transform:none;}.hero.ready .big{opacity:1;transform:none;}

.band{padding:118px 0;}
.band--ink{background:var(--ink);}.band--navy{background:var(--navy);}
.head{max-width:820px;margin:0 0 60px;}

/* pricing tiers */
.tiers{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;}
.tier{position:relative;border:1px solid var(--line);border-radius:8px;padding:42px 34px 36px;background:rgba(168,207,224,.02);display:flex;flex-direction:column;transition:border-color .5s var(--ease),transform .5s var(--ease);}
.tier:hover{border-color:var(--line-2);transform:translateY(-4px);}
.tier.feat{border-color:var(--cta-line);background:rgba(168,207,224,.06);}
.tier .badge{position:absolute;top:-12px;left:34px;font-size:9.5px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;background:var(--blue);color:var(--ink);padding:6px 13px;border-radius:999px;}
.tier .dur{font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--blue-soft);}
.tier .price{font-family:var(--sans);font-weight:600;font-size:clamp(38px,4vw,50px);letter-spacing:-.02em;color:var(--cream);margin:14px 0 2px;}
.tier .per{font-size:13px;color:var(--muted);margin:0 0 26px;}
.tier dl{margin:0 0 30px;display:flex;flex-direction:column;}
.tier dl div{display:flex;justify-content:space-between;gap:16px;padding:13px 0;border-top:1px solid var(--line);}
.tier dt{font-size:11px;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);}
.tier dd{margin:0;font-size:14px;color:var(--cream);text-align:right;}
.tier .btn{margin-top:auto;width:100%;justify-content:center;}

/* feature grid */
.features{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);margin-top:8px;}
.feature{background:var(--navy);padding:38px 32px;}
.feature h4{margin:0 0 12px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--blue-soft);}
.feature p{margin:0;color:rgba(244,246,248,.7);font-size:14.5px;line-height:1.7;}

/* included + day split */
.split2{display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,72px);align-items:start;}
.incl{margin:0;padding:0;list-style:none;display:grid;gap:13px;}
.incl li{position:relative;padding-left:26px;color:rgba(244,246,248,.74);font-size:15px;line-height:1.6;}
.incl li::before{content:"✓";position:absolute;left:0;top:0;color:var(--blue);font-size:14px;}
.daybody p{color:rgba(244,246,248,.74);font-size:16px;line-height:1.84;margin:0 0 18px;}
.daybody p:last-child{margin-bottom:0;}
.daybody .pull{font-family:var(--serif);font-style:italic;font-size:clamp(20px,2.4vw,26px);color:var(--blue-soft);line-height:1.5;}

/* timeline */
.tl{margin-top:8px;border-top:1px solid var(--line);}
.tlrow{display:grid;grid-template-columns:120px 1fr;gap:40px;padding:30px 0;border-bottom:1px solid var(--line);}
.tlrow .t{font-weight:600;font-size:18px;color:var(--cream);letter-spacing:.01em;}
.tlrow p{margin:0;color:rgba(244,246,248,.68);font-size:15px;line-height:1.74;}

/* gallery */
.gal{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:280px;gap:16px;margin-top:56px;}
.gal a{overflow:hidden;border-radius:4px;background:var(--panel);}
.gal img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s var(--ease);}
.gal a:hover img{transform:scale(1.05);}
.gal a.wide{grid-column:span 2;}

.note{font-size:13px;color:var(--muted);line-height:1.7;margin-top:30px;max-width:90ch;}

.cta{background:var(--navy);text-align:center;padding:120px 0;border-top:1px solid var(--line);}
.cta .eyebrow{justify-content:center;display:flex;width:max-content;margin:0 auto 26px;}
.cta h2{margin:0 auto 38px;font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(30px,4vw,54px);line-height:1.04;color:var(--cream);max-width:20ch;}
.cta h2 .s{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}
.btn{display:inline-flex;align-items:center;gap:14px;cursor:pointer;background:transparent;border:1px solid var(--cta-line);border-radius:var(--radius);color:var(--cream);font-family:inherit;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;padding:17px 40px;position:relative;overflow:hidden;transition:border-color .6s var(--ease);}
.btn::before{content:"";position:absolute;inset:0;background:rgba(168,207,224,.12);transform:scaleX(0);transform-origin:left;transition:transform .6s var(--ease);}
.btn span{position:relative;z-index:1;}.btn .arw{position:relative;z-index:1;transition:transform .6s var(--ease);}
.btn:hover{border-color:rgba(168,207,224,.8);}.btn:hover::before{transform:scaleX(1);}.btn:hover .arw{transform:translateX(6px);}
.btn--solid{background:var(--blue);border-color:var(--blue);color:var(--ink);}
.btn--solid::before{background:rgba(255,255,255,.18);}

.sf{background:var(--ink);border-top:1px solid var(--line);}
.sf .shell{padding:60px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:62px;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
.sf__nav a{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,246,248,.72);}.sf__nav a:hover{color:var(--blue-soft);}
.sf__mid{text-align:center;border-top:1px solid var(--line);padding:58px 0 0;}
.sf__mid .big{font-family:var(--serif);font-style:italic;font-size:clamp(30px,5.6vw,72px);color:var(--cream);}
.sf__trust{margin:34px 0 56px;text-align:center;font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,.5);}
.sf__trust b{font-weight:600;color:var(--blue-soft);}
.sf__base{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px;}
.sf__base .cr{font-size:11px;color:rgba(244,246,248,.32);}
.sf__base a{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(168,207,224,.72);}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s var(--ease),transform .9s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media (prefers-reduced-motion:reduce){.reveal,.hero__photo,.hero .eyebrow,.hero .big{opacity:1!important;transform:none!important;transition:none!important;}*{scroll-behavior:auto!important;}}
@media(max-width:560px){.eyebrow{flex-wrap:wrap;letter-spacing:.2em;}.cta .eyebrow{width:auto;max-width:100%;}}

@media(max-width:980px){.tiers{grid-template-columns:1fr;max-width:460px;}.features{grid-template-columns:1fr 1fr;}.split2{grid-template-columns:1fr;gap:40px;}.gal{grid-template-columns:1fr 1fr;}.gal a.wide{grid-column:span 2;}}
@media(max-width:900px){
  .shell{padding:0 24px;}.burger{display:flex;}
  .menu{position:fixed;top:0;right:0;bottom:0;width:min(80vw,360px);background:rgba(10,22,40,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px 36px;transform:translateX(100%);transition:transform .6s var(--ease);}
  body.nav-open .menu{transform:none;}
  .menu a{font-size:18px;letter-spacing:.06em;text-transform:none;padding:14px 0;color:var(--cream);}.menu a::after{display:none;}
  .hero{min-height:74vh;padding-bottom:60px;}
  .band{padding:76px 0;}
  .features{grid-template-columns:1fr;}
  .tlrow{grid-template-columns:84px 1fr;gap:20px;}
  .gal{grid-template-columns:1fr;grid-auto-rows:240px;}.gal a.wide{grid-column:span 1;}
  .sf__top,.sf__base{flex-direction:column;align-items:flex-start;gap:14px;}
}
</style>

<script is:inline>
var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),heroEl=document.getElementById('hero'),hp=document.getElementById('heroPhoto');
function onScroll(){var y=window.scrollY,vh=window.innerHeight;hdr.classList.toggle('scrolled',y>40);var h=document.documentElement.scrollHeight-vh;prog.style.width=(h>0?(y/h*100):0)+'%';if(y<vh&&hp){hp.style.transform='translateY('+(y*0.16)+'px) scale(1)';}}
onScroll();window.addEventListener('scroll',onScroll,{passive:true});
requestAnimationFrame(function(){setTimeout(function(){heroEl.classList.add('ready');},140);});
var burger=document.getElementById('burger');function setMenu(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');}
burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});
var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){var sibs=Array.prototype.slice.call(en.target.parentNode.children).filter(function(c){return c.classList.contains('reveal');});en.target.style.transitionDelay=(Math.max(0,sibs.indexOf(en.target))*0.05)+'s';en.target.classList.add('in');io.unobserve(en.target);}});},{threshold:0.08,rootMargin:'0px 0px -5% 0px'});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
</script>
