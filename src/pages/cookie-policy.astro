---
import Base from '../layouts/Base.astro';
const body = `
<section class="legalpage">
  <div class="shell">
    <p class="eyebrow">Legal</p>
    <h1>Cookie Policy</h1>
    <p class="updated">Effective 6 July 2026</p>
    <div class="legal-body">

      <p>This policy explains how heliskitravel.com uses cookies and similar technologies. It applies alongside our <a href="/privacy-policy">Privacy Policy</a>. Because we address customers in Norway and the EEA, we ask for your prior consent before setting any non-essential cookies, as required by the GDPR and Norwegian ekomloven.</p>

      <h2>What cookies are</h2>
      <p>Cookies are small text files placed on your device when you visit a website. They help the site work, remember your preferences, and — where you allow it — measure how the site is used.</p>

      <h2>The cookies we use</h2>
      <p>We keep cookies to a minimum. They fall into three categories:</p>
      <ul>
        <li><strong>Essential cookies</strong> — necessary for the site to function securely (for example, remembering your cookie choices or basic session state). These are always active and do not require consent.</li>
        <li><strong>Analytics cookies</strong> — if enabled, these help us understand how visitors use the site so we can improve it. They are only set with your consent.</li>
        <li><strong>Marketing cookies</strong> — if we run advertising campaigns, these may be set by partners such as Google or Meta to measure and target advertising. They are only set with your consent.</li>
      </ul>
      <p>At present the site runs only essential cookies and does not load analytics or marketing trackers by default. If we introduce them, a consent banner will list each cookie with its provider and lifespan, and no analytics or advertising cookie will be set before you have given consent.</p>

      <h2>Managing and withdrawing consent</h2>
      <p>Where a consent banner is shown, you can accept or decline non-essential categories, and you can change or withdraw your choice at any time via the cookie settings link. You can also block or delete cookies through your browser settings, though disabling essential cookies may affect how the site works.</p>

      <h2>Changes to this policy</h2>
      <p>We may update this policy as our use of cookies changes. The current version is always published here with its effective date.</p>

      <h2>Contact</h2>
      <p>Questions? Email <a href="mailto:hello@heliskitravel.com">hello@heliskitravel.com</a>. See also our <a href="/privacy-policy">Privacy Policy</a> and <a href="/imprint">Imprint</a>.</p>
    </div>
  </div>
</section>
`;
---
<Base title="Cookie Policy | Heliski Travel" description="How heliskitravel.com uses cookies, and how to manage or withdraw your consent, in line with the GDPR and Swiss law." active="">
  <Fragment set:html={body} />
  <script is:inline>
    (function(){var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),burger=document.getElementById('burger');
      var __maxS=0;function __recalc(){__maxS=document.documentElement.scrollHeight-window.innerHeight;}__recalc();window.addEventListener('resize',__recalc,{passive:true});window.addEventListener('load',__recalc);
function onScroll(){var y=window.scrollY,vh=window.innerHeight;if(hdr)hdr.classList.toggle('scrolled',y>40);if(prog){var h=__maxS;prog.style.width=(h>0?(y/h*100):0)+'%';}}
      onScroll();window.addEventListener('scroll',onScroll,{passive:true});
      if(burger){var setMenu=function(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');};
        burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
        document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});}
    })();
  </script>
</Base>
