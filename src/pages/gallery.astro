---
import Base from '../layouts/Base.astro';
const body = `

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__photo" id="heroPhoto"></div>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell"><h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Gallery — Iceland Heliskiing in Film and Photos</h1></div>
</section>

<!-- FILMS -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Films · press play</p>
      <h2 class="sectit">Watch the <span class="s">week move.</span></h2>
      <p class="intro">Two short films from the Troll Peninsula. Tap either to play with sound.</p>
    </div>
    <div class="films reveal">
      <button class="vcard" type="button" data-video="/videos/gallery-teaser.mp4" aria-label="Play the 2026 teaser film">
        <img src="/videos/gallery-teaser-poster.jpg" alt="Helicopter flying through a sunlit snow couloir in Iceland" loading="lazy" />
        <span class="play"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="vmeta"><span class="vt">The 2026 Teaser</span><span class="vd">Viking Heliskiing · 1:00</span></span>
      </button>
      <button class="vcard" type="button" data-video="/videos/gallery-vh.mp4" aria-label="Play the aerial film of Siglufjörður and the fjords">
        <img src="/videos/gallery-vh-poster.jpg" alt="Aerial view over the fjords around Siglufjörður, North Iceland" loading="lazy" />
        <span class="play"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z"/></svg></span>
        <span class="vmeta"><span class="vt">Sigló &amp; the Fjords</span><span class="vd">Aerial film · 0:24</span></span>
      </button>
    </div>
  </div>
</section>

<!-- GALLERY GRID -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Stills</p>
      <h2 class="sectit">A season <span class="s">in pictures.</span></h2>
      <p class="intro">Shot across the Troll Peninsula around Siglufjörður. Click any frame to open it full-screen.</p>
    </div>
    <div class="gal reveal">
      <a class="big" href="/images/gallery/northern-lights-heliski-helicopter-iceland.webp"><img src="/images/gallery/northern-lights-heliski-helicopter-iceland.webp" alt="The Northern Lights glowing green over a heliski helicopter on the Troll Peninsula, North Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/summit-bonfire-apres-heliski-iceland.webp"><img src="/images/gallery/summit-bonfire-apres-heliski-iceland.webp" alt="Heliski guests around a summit bonfire with charcuterie at sunset, helicopter above the fjord, Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliskiers-sunset-arctic-ocean-iceland.webp"><img src="/images/gallery/heliskiers-sunset-arctic-ocean-iceland.webp" alt="Two heliskiers pausing at sunset above the Arctic Ocean, Troll Peninsula Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a class="big" href="/images/gallery/heliskiers-descent-fjord-helicopter-iceland.webp"><img src="/images/gallery/heliskiers-descent-fjord-helicopter-iceland.webp" alt="Four heliskiers descending toward the Arctic fjord with the helicopter hovering, Troll Peninsula Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliski-guides-ridge-sunset-iceland.webp"><img src="/images/gallery/heliski-guides-ridge-sunset-iceland.webp" alt="A heliski group silhouetted on a summit ridge at sunset in North Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliskiing-helicopter-snow-ridge-iceland.webp"><img src="/images/gallery/heliskiing-helicopter-snow-ridge-iceland.webp" alt="A heliskiing helicopter landed high on a snow ridge in the Icelandic mountains" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a class="big" href="/images/gallery/golden-fjord-reflection-siglufjordur-iceland.webp"><img src="/images/gallery/golden-fjord-reflection-siglufjordur-iceland.webp" alt="Snow peaks mirrored in a golden fjord at sunset near Siglufjordur, Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliskier-arctic-powder-turn-iceland.webp"><img src="/images/gallery/heliskier-arctic-powder-turn-iceland.webp" alt="A heliskier carving a turn through deep Arctic powder in North Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/snowboarders-sunset-helicopter-iceland.webp"><img src="/images/gallery/snowboarders-sunset-helicopter-iceland.webp" alt="Snowboarders on a ridge above a cloud inversion at sunset as the Viking helicopter lands, North Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a class="big" href="/images/gallery/cinematic-ski-descent-wide-face-iceland.webp"><img src="/images/gallery/cinematic-ski-descent-wide-face-iceland.webp" alt="A skier laying fresh tracks down a wide Iceland mountain face" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/helicopter-cockpit-view-iceland-peaks.webp"><img src="/images/gallery/helicopter-cockpit-view-iceland-peaks.webp" alt="The view from the helicopter cockpit over Iceland snow peaks on the way to the run" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/aerial-heliski-descent-iceland-powder.webp"><img src="/images/gallery/aerial-heliski-descent-iceland-powder.webp" alt="Aerial drone view of a skier descending untracked Iceland powder" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a class="big" href="/images/gallery/siglufjordur-heliski-base-fjord-aerial.webp"><img src="/images/gallery/siglufjordur-heliski-base-fjord-aerial.webp" alt="Aerial of Siglufjordur, the northernmost heliski base in Iceland, ringed by snow mountains" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliski-mountain-field-lunch-iceland.webp"><img src="/images/gallery/heliski-mountain-field-lunch-iceland.webp" alt="A heliski group enjoying a field lunch on the mountain between runs, Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/skier-summit-blue-sky-troll-peninsula.webp"><img src="/images/gallery/skier-summit-blue-sky-troll-peninsula.webp" alt="A skier on a summit under clear blue Arctic sky, Troll Peninsula Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a class="big" href="/images/gallery/midnight-sun-fjord-heliski-iceland.webp"><img src="/images/gallery/midnight-sun-fjord-heliski-iceland.webp" alt="Midnight sun glowing over an Iceland fjord during a spring heliski week" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/snow-peaks-north-iceland-fjord.webp"><img src="/images/gallery/snow-peaks-north-iceland-fjord.webp" alt="Snow-covered peaks rising above a North Iceland fjord" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliskier-arctic-powder-spray-iceland.webp"><img src="/images/gallery/heliskier-arctic-powder-spray-iceland.webp" alt="A heliskier throwing up spray through Arctic powder in Iceland" loading="lazy" /><span class="zoom">&#10530;</span></a>
      <a href="/images/gallery/heliski-helicopter-guests-sunset-iceland.webp"><img src="/images/gallery/heliski-helicopter-guests-sunset-iceland.webp" alt="A heliski helicopter and guests at sunset in the North Iceland mountains" loading="lazy" /><span class="zoom">&#10530;</span></a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="shell">
    <p class="eyebrow">Your turn</p>
    <h2>Come make your own <span class="s">frames.</span></h2>
    <div><a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
  </div>
</section>

<!-- VIDEO POPUP -->
<div class="vpop" id="vpop" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Video player">
  <button class="vpop__x" id="vpopX" type="button" aria-label="Close video">&times;</button>
  <div class="vpop__frame"><video id="vpopV" playsinline controls preload="none"><track kind="captions" src="/videos/empty.vtt" srclang="en" label="No dialogue" /></video></div>
</div>

<!-- FOOTER -->
`;
---
<Base title="Gallery: Iceland Heliskiing in Film & Photos | Heliski Travel" description="A gallery of Viking Heliskiing on the Troll Peninsula, North Iceland — films and photographs of powder skiing, the helicopter, fjords, midnight sun and the Northern Lights." active="gallery" image="/images/gallery/northern-lights-heliski-helicopter-iceland.jpg">
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"proxima-nova","Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/gallery-hero.webp");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--sans);font-weight:600;letter-spacing:-.015em;font-size:clamp(36px,5.4vw,64px);line-height:1.02;color:var(--cream);margin:22px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.04em;line-height:1;letter-spacing:0;}
.intro{margin:28px 0 0;color:rgba(244,246,248,.68);font-size:17px;line-height:1.8;max-width:62ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}.submenu{position:static;opacity:1;visibility:visible;transform:none;background:none;border:0;box-shadow:none;padding:4px 0 2px 16px;margin:0;min-width:0;}.submenu::before{display:none;}.submenu a{padding:10px 0;font-size:15px;text-transform:none;letter-spacing:.04em;color:rgba(244,246,248,.7);}}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}

.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding:0 0 110px;overflow:hidden;background:var(--navy);}
.hero__photo{position:absolute;inset:-3%;z-index:0;background:var(--hero) center 46%/cover no-repeat;background-color:var(--navy);opacity:1;transform:scale(1.08);transition:transform 2.4s var(--ease);}
.hero.ready .hero__photo{opacity:1;transform:scale(1);}
.hero .grade{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(180deg,rgba(10,22,40,.34) 0%,rgba(10,22,40,0) 22%),linear-gradient(90deg,rgba(10,22,40,.16) 0%,rgba(10,22,40,0) 52%);}
.hero .shell{position:relative;z-index:3;}
.scrolldn{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;opacity:0;transition:opacity 1s var(--ease) 1.4s;cursor:pointer;}
.hero.ready .scrolldn{opacity:1;}
.scrolldn span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:scrolldn 1.9s var(--ease) infinite;}
@keyframes scrolldn{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}
.hero .eyebrow{margin-bottom:26px;opacity:0;transform:translateY(12px);transition:opacity 1s var(--ease) .5s,transform 1s var(--ease) .5s;}
.hero .big{margin:0;font-family:var(--sans);font-weight:600;letter-spacing:-.02em;font-size:clamp(40px,6vw,86px);line-height:.92;color:var(--cream);opacity:0;transform:translateY(20px);transition:opacity 1.2s var(--ease) .72s,transform 1.2s var(--ease) .72s;}
.hero .big .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;letter-spacing:0;color:var(--blue-soft);}
.hero .hlead{margin:26px 0 0;max-width:52ch;font-size:16.5px;line-height:1.75;color:rgba(244,246,248,.74);opacity:0;transform:translateY(16px);transition:opacity 1.2s var(--ease) .92s,transform 1.2s var(--ease) .92s;}
.hero.ready .eyebrow{opacity:1;transform:none;}.hero.ready .big{opacity:1;transform:none;}.hero.ready .hlead{opacity:1;transform:none;}

.band{padding:112px 0;}
.band--ink{background:var(--ink);}.band--navy{background:var(--navy);}
.head{max-width:820px;margin:0 0 18px;}

/* films */
.films{display:grid;grid-template-columns:1fr 1fr;gap:22px;margin-top:54px;}
.vcard{position:relative;display:block;width:100%;padding:0;border:1px solid var(--line);border-radius:10px;overflow:hidden;cursor:pointer;aspect-ratio:16/10;background:var(--navy);font-family:inherit;}
.vcard img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s var(--ease);}
.vcard:hover img{transform:scale(1.06);}
.vcard::before{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,22,40,.1) 0%,rgba(10,22,40,0) 34%,rgba(10,22,40,.62) 100%);transition:background .5s var(--ease);}
.vcard .play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);z-index:2;width:78px;height:78px;border-radius:50%;background:rgba(244,246,248,.14);border:1.5px solid rgba(244,246,248,.72);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;transition:background .4s var(--ease),transform .4s var(--ease),border-color .4s;}
.vcard:hover .play{background:var(--blue);border-color:var(--blue);transform:translate(-50%,-50%) scale(1.09);}
.vcard .play svg{width:26px;height:26px;margin-left:4px;fill:var(--cream);transition:fill .4s;}
.vcard:hover .play svg{fill:var(--ink);}
.vcard .vmeta{position:absolute;left:0;right:0;bottom:0;z-index:2;padding:24px 28px;display:flex;justify-content:space-between;align-items:flex-end;gap:12px;text-align:left;}
.vcard .vt{font-family:var(--serif);font-style:italic;font-size:25px;color:var(--cream);line-height:1.05;}
.vcard .vd{font-size:10px;letter-spacing:.18em;text-transform:uppercase;color:var(--blue-soft);white-space:nowrap;padding-bottom:6px;}

/* gallery mosaic — big + small on a uniform square grid, gap-free */
.gal{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin-top:54px;grid-auto-flow:dense;}
.gal a{position:relative;display:block;overflow:hidden;border-radius:8px;background:var(--panel);aspect-ratio:1;cursor:zoom-in;}
.gal a.big{grid-column:span 2;grid-row:span 2;}
.gal img{width:100%;height:100%;object-fit:cover;transition:transform 1.2s var(--ease);}
.gal a::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,22,40,0) 55%,rgba(10,22,40,.42));opacity:0;transition:opacity .5s var(--ease);}
.gal a:hover img{transform:scale(1.07);}
.gal a:hover::after{opacity:1;}
.gal .zoom{position:absolute;top:13px;right:13px;z-index:2;width:34px;height:34px;border-radius:50%;background:rgba(10,22,40,.5);border:1px solid rgba(195,220,238,.4);display:flex;align-items:center;justify-content:center;color:var(--cream);font-size:14px;opacity:0;transform:scale(.8);transition:opacity .45s var(--ease),transform .45s var(--ease);backdrop-filter:blur(4px);-webkit-backdrop-filter:blur(4px);}
.gal a:hover .zoom{opacity:1;transform:none;}

/* video popup */
.vpop{position:fixed;inset:0;z-index:240;display:none;align-items:center;justify-content:center;padding:24px;background:rgba(6,12,22,.94);-webkit-backdrop-filter:blur(10px);backdrop-filter:blur(10px);opacity:0;transition:opacity .4s var(--ease);}
.vpop.open{display:flex;opacity:1;}
.vpop__frame{position:relative;width:min(1120px,94vw);aspect-ratio:16/9;box-shadow:0 50px 130px rgba(0,0,0,.7);border-radius:8px;overflow:hidden;transform:scale(.97);transition:transform .5s var(--ease);}
.vpop.open .vpop__frame{transform:none;}
.vpop video{width:100%;height:100%;background:#000;display:block;}
.vpop__x{position:absolute;top:20px;right:24px;z-index:2;width:48px;height:48px;border-radius:50%;border:1px solid rgba(195,220,238,.4);background:rgba(10,22,40,.55);color:var(--cream);font-size:24px;line-height:1;cursor:pointer;transition:background .3s;}
.vpop__x:hover{background:rgba(168,207,224,.2);}

.cta{background:var(--navy);text-align:center;padding:120px 0;border-top:1px solid var(--line);}
.cta .eyebrow{justify-content:center;display:flex;width:max-content;margin:0 auto 26px;}
.cta h2{margin:0 auto 38px;font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(30px,4vw,54px);line-height:1.04;color:var(--cream);max-width:20ch;}
.cta h2 .s{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}
.btn{display:inline-flex;align-items:center;gap:16px;cursor:pointer;background:transparent;border:1px solid var(--cta-line);border-radius:var(--radius);color:var(--cream);font-family:inherit;font-size:11px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;padding:18px 52px;position:relative;overflow:hidden;transition:border-color .6s var(--ease);}
.btn::before{content:"";position:absolute;inset:0;background:rgba(168,207,224,.12);transform:scaleX(0);transform-origin:left;transition:transform .6s var(--ease);}
.btn span{position:relative;z-index:1;}.btn .arw{position:relative;z-index:1;transition:transform .6s var(--ease);}
.btn:hover{border-color:rgba(168,207,224,.8);}.btn:hover::before{transform:scaleX(1);}.btn:hover .arw{transform:translateX(6px);}

.sf{background:var(--ink);border-top:1px solid var(--line);}
.sf .shell{padding:60px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:62px;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
.sf__nav a{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,246,248,.72);}.sf__nav a:hover{color:var(--blue-soft);}
.sf__mid{text-align:center;border-top:1px solid var(--line);padding:58px 0 0;}
.sf__mid .big{font-family:var(--serif);font-style:italic;font-size:clamp(30px,5.6vw,72px);color:var(--cream);}
.sf__trust{margin:34px 0 56px;text-align:center;font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,.5);}
.sf__trust b{font-weight:600;color:var(--blue-soft);}
.sf__base{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px;}
.sf__base .cr{font-size:11px;color:rgba(244,246,248,.32);}
.sf__base a{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(168,207,224,.72);}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s var(--ease),transform .9s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media (prefers-reduced-motion:reduce){.reveal,.hero__photo,.hero .eyebrow,.hero .big,.hero .hlead{opacity:1!important;transform:none!important;transition:none!important;}*{scroll-behavior:auto!important;}}

@media(max-width:820px){
  .films{grid-template-columns:1fr;}
  .gal{grid-template-columns:1fr 1fr;}
  .vcard .vt{font-size:21px;}
}
@media(max-width:900px){
  .shell{padding:0 24px;}.burger{display:flex;}
  .menu{position:fixed;top:0;right:0;bottom:0;width:min(80vw,360px);background:rgba(10,22,40,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px 36px;transform:translateX(100%);transition:transform .6s var(--ease);}
  body.nav-open .menu{transform:none;}
  .menu a{font-size:18px;letter-spacing:.06em;text-transform:none;padding:14px 0;color:var(--cream);}.menu a::after{display:none;}
  .hero{min-height:78vh;padding-bottom:80px;}
  .band{padding:74px 0;}
}
@media(max-width:540px){
  .gal{grid-template-columns:1fr;}
  .gal a{aspect-ratio:4/3;}
  .gal a.big{grid-column:auto;grid-row:auto;}
}
</style>

<script is:inline>
var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),heroEl=document.getElementById('hero'),hp=document.getElementById('heroPhoto');
function onScroll(){var y=window.scrollY,vh=window.innerHeight;hdr.classList.toggle('scrolled',y>40);var h=document.documentElement.scrollHeight-vh;prog.style.width=(h>0?(y/h*100):0)+'%';if(y<vh&&hp){hp.style.transform='translateY('+(y*0.16)+'px) scale(1)';}}
onScroll();window.addEventListener('scroll',onScroll,{passive:true});
requestAnimationFrame(function(){setTimeout(function(){heroEl.classList.add('ready');},140);});
var burger=document.getElementById('burger');function setMenu(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');}
burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});
var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){var sibs=Array.prototype.slice.call(en.target.parentNode.children).filter(function(c){return c.classList.contains('reveal');});en.target.style.transitionDelay=(Math.max(0,sibs.indexOf(en.target))*0.05)+'s';en.target.classList.add('in');io.unobserve(en.target);}});},{threshold:0.08,rootMargin:'0px 0px -5% 0px'});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});

/* video popup player */
(function(){
  var vp=document.getElementById('vpop'),vv=document.getElementById('vpopV'),vx=document.getElementById('vpopX');
  if(!vp)return;
  function openV(src){vv.src=src;vp.classList.add('open');vp.setAttribute('aria-hidden','false');document.documentElement.style.overflow='hidden';var p=vv.play();if(p&&p.catch)p.catch(function(){});}
  function closeV(){vp.classList.remove('open');vp.setAttribute('aria-hidden','true');document.documentElement.style.overflow='';try{vv.pause();}catch(e){}vv.removeAttribute('src');vv.load();}
  document.querySelectorAll('[data-video]').forEach(function(c){c.addEventListener('click',function(){openV(c.getAttribute('data-video'));});});
  vx.addEventListener('click',closeV);
  vp.addEventListener('click',function(e){if(e.target===vp)closeV();});
  document.addEventListener('keydown',function(e){if(e.key==='Escape'&&vp.classList.contains('open'))closeV();});
})();
</script>
