---
import Base from '../layouts/Base.astro';
const SITE = 'https://heliskitravel.vercel.app';
const chapters = [
  { n:'01', slug:'what-is-heliskiing', h:'What Is Heliskiing?', p:'How it works, where it came from, and how it compares to cat-skiing and the resort.' },
  { n:'02', slug:'troll-peninsula-terrain', h:'The Troll Peninsula & Its Terrain', p:'Eleven mapped zones, sea-to-summit descents, and just how much you ski in a day.' },
  { n:'03', slug:'best-time-to-heliski-iceland', h:'The Best Time to Go', p:'The season month by month, powder versus corn, the midnight sun and the Northern Lights.' },
  { n:'04', slug:'heliskiing-cost-iceland', h:'Cost & What’s Included', p:'Pricing by guaranteed vertical feet, packages, private versus shared, and real value.' },
  { n:'05', slug:'heliskiing-safety-guides', h:'Safety, Avalanches & Guides', p:'IFMGA guiding, avalanche management, the helicopter and the insurance you need.' },
  { n:'06', slug:'who-can-heliski', h:'Who Can Go', p:'Ability and fitness, first-timers, snowboarding, and trips for groups and families.' },
  { n:'07', slug:'heliski-gear-packing', h:'Gear & Packing', p:'The K2 fleet, your avalanche kit, and a complete, no-nonsense packing checklist.' },
  { n:'08', slug:'getting-to-iceland-heliskiing', h:'Getting There', p:'Flights, Reykjavík and Akureyri, transfers, and building a full Iceland trip around it.' },
  { n:'09', slug:'siglo-hotel-siglufjordur', h:'Where You Stay', p:'Sigló Hótel, the town of Siglufjörður, dining and life at base — for skiers and non-skiers.' },
  { n:'10', slug:'iceland-vs-worlds-best', h:'Iceland vs the World', p:'How Iceland compares to Canada, Alaska and Japan — and why so many now choose it.' }
];
const catOrder = ['Destinations','Compare & Decide','Cost & Booking','Plan & Prepare','On the Mountain','Iceland & the Experience'];
const articles = [
  { slug:'best-heliskiing-destinations-world', h:'The Best Heliskiing Destinations in the World', d:'Alaska, BC, Iceland, Japan and beyond, ranked.', cat:'Destinations' },
  { slug:'is-heliskiing-worth-it', h:'Is Heliskiing Worth It?', d:'An honest verdict on cost, risk and reward.', cat:'Compare & Decide' },
  { slug:'heliskiing-vs-cat-skiing-vs-touring', h:'Heliskiing vs Cat Skiing vs Ski Touring', d:'Three ways into the backcountry, compared.', cat:'Compare & Decide' },
  { slug:'heliskiing-for-beginners', h:'Heliskiing for Beginners', d:'The ability you need and how day one unfolds.', cat:'Plan & Prepare' },
  { slug:'how-to-choose-heliski-operator', h:'How to Choose a Heliski Operator', d:'The buyer’s checklist and the red flags.', cat:'Compare & Decide' },
  { slug:'heliskiing-in-alaska', h:'Heliskiing in Alaska', d:'The steepest big-mountain terrain on earth.', cat:'Destinations' },
  { slug:'heliskiing-in-british-columbia', h:'Heliskiing in British Columbia', d:'The birthplace — deep, reliable powder.', cat:'Destinations' },
  { slug:'heliskiing-in-japan', h:'Heliskiing in Japan', d:'The truth about Japow and heli access.', cat:'Destinations' },
  { slug:'heliskiing-in-norway', h:'Heliskiing in Norway', d:'Arctic sea-to-summit in Lyngen and Lofoten.', cat:'Destinations' },
  { slug:'best-time-to-go-heliskiing', h:'When Is the Best Time to Go Heliskiing?', d:'A month-by-month, region-by-region guide.', cat:'Plan & Prepare' },
  { slug:'heliskiing-in-new-zealand', h:'Heliskiing in New Zealand', d:'The standout Northern-summer option.', cat:'Destinations' },
  { slug:'heliskiing-in-the-alps', h:'Heliskiing in the Alps', d:'Where heli-skiing is actually allowed in Europe.', cat:'Destinations' },
  { slug:'heliskiing-in-georgia-caucasus', h:'Heliskiing in Georgia (the Caucasus)', d:'Big terrain at a lower price.', cat:'Destinations' },
  { slug:'canada-vs-alaska-heliskiing', h:'Canada vs Alaska Heliskiing', d:'An even-handed verdict on the two flagships.', cat:'Compare & Decide' },
  { slug:'how-much-does-heliskiing-cost', h:'How Much Does Heliskiing Cost?', d:'What drives the price and what’s included.', cat:'Cost & Booking' },
  { slug:'is-heliskiing-safe', h:'Is Heliskiing Safe?', d:'The real risks and how operators manage them.', cat:'On the Mountain' },
  { slug:'what-to-pack-for-heliskiing', h:'What to Pack for Heliskiing', d:'The complete checklist, nothing forgotten.', cat:'Plan & Prepare' },
  { slug:'heliskiing-fitness-guide', h:'How Fit Do You Need to Be for Heliskiing?', d:'What the sport demands and how to train.', cat:'Plan & Prepare' },
  { slug:'private-vs-shared-helicopter-heliskiing', h:'Private vs Shared Helicopter Heliskiing', d:'What each format means for your day.', cat:'Cost & Booking' },
  { slug:'heliskiing-vs-resort-skiing', h:'Heliskiing vs Resort Skiing', d:'Is it worth the upgrade?', cat:'Compare & Decide' },
  { slug:'what-is-sea-to-summit-skiing', h:'What Is Sea-to-Summit Skiing?', d:'Summit to the Arctic Ocean in one run.', cat:'Iceland & the Experience' },
  { slug:'how-to-ski-powder', h:'How to Ski Powder', d:'The technique that makes deep snow a joy.', cat:'On the Mountain' },
  { slug:'heliskiing-for-intermediate-skiers', h:'Heliskiing for Intermediate Skiers', d:'You do not have to be an expert.', cat:'Plan & Prepare' },
  { slug:'northern-lights-and-midnight-sun-heliskiing', h:'Northern Lights & Midnight Sun Heliskiing', d:'Iceland’s two celestial seasons.', cat:'Iceland & the Experience' },
  { slug:'heliboarding-snowboard-heliskiing', h:'Heliboarding: Heliskiing on a Snowboard', d:'Yes, snowboarders are welcome.', cat:'On the Mountain' },
  { slug:'heliskiing-in-greenland', h:'Heliskiing in Greenland', d:'The sport’s ultimate remote frontier.', cat:'Destinations' },
  { slug:'heliskiing-in-kashmir-india', h:'Heliskiing in Kashmir', d:'Himalayan heliskiing above Gulmarg.', cat:'Destinations' },
  { slug:'heliskiing-in-usa', h:'Heliskiing in the USA', d:'Beyond Alaska — Utah, Colorado, the Rubies.', cat:'Destinations' },
  { slug:'heliskiing-in-the-andes-chile-argentina', h:'Heliskiing in the Andes', d:'Chile and Argentina in your summer.', cat:'Destinations' },
  { slug:'planning-your-first-heliski-trip', h:'Planning Your First Heliski Trip', d:'The complete step-by-step roadmap.', cat:'Plan & Prepare' },
  { slug:'heliskiing-vs-heli-assisted-touring', h:'Heliskiing vs Heli-Assisted Touring', d:'Let the heli climb, or earn some turns?', cat:'Compare & Decide' },
  { slug:'what-is-guaranteed-vertical-feet', h:'What Is Guaranteed Vertical Feet?', d:'How packages are measured and priced.', cat:'Cost & Booking' },
  { slug:'best-skis-for-heliskiing', h:'Best Skis for Heliskiing', d:'Width, rocker, and rent-or-bring.', cat:'Plan & Prepare' },
  { slug:'avalanche-safety-for-heliskiing', h:'Avalanche Safety for Heliskiing', d:'Transceiver, shovel, probe — explained.', cat:'On the Mountain' },
  { slug:'heliskiing-insurance-guide', h:'Heliskiing Insurance', d:'Why standard cover often falls short.', cat:'Cost & Booking' },
  { slug:'what-to-expect-first-heliski-day', h:'Your First Heliski Day', d:'An hour-by-hour walkthrough.', cat:'On the Mountain' },
  { slug:'weather-and-down-days-heliskiing', h:'Weather and Down-Days in Heliskiing', d:'What happens when you cannot fly.', cat:'Plan & Prepare' },
  { slug:'heliskiing-for-groups-and-families', h:'Heliskiing for Groups and Families', d:'Private helicopters and mixed abilities.', cat:'Iceland & the Experience' },
  { slug:'solo-heliskiing', h:'Heliskiing Solo', d:'How shared groups work, and why it’s great.', cat:'Iceland & the Experience' },
  { slug:'heliskiing-terminology-glossary', h:'Heliskiing Terminology: A Glossary', d:'Every term, from spines to companion rescue.', cat:'On the Mountain' },
  { slug:'getting-to-north-iceland-heliskiing', h:'Getting to North Iceland', d:'Via Keflavík and Akureyri to Siglufjörður.', cat:'Plan & Prepare' },
  { slug:'siglufjordur-travel-guide', h:'Siglufjörður: The Heliski Base Town', d:'The herring-era town you’ll call home.', cat:'Iceland & the Experience' },
  { slug:'iceland-in-spring-what-to-expect', h:'Iceland in Spring: What to Expect', d:'Weather, daylight and snow, March to June.', cat:'Iceland & the Experience' },
  { slug:'why-book-heliskiing-through-an-agent', h:'Why Book Through an Agent', d:'Same price as direct — so what do you gain?', cat:'Compare & Decide' },
  { slug:'heliskiing-iceland-vs-norway', h:'Iceland vs Norway for Heliskiing', d:'Two Arctic sea-to-summit siblings, compared.', cat:'Compare & Decide' },
  { slug:'the-heliski-lodge-experience', h:'The Heliski Lodge Experience', d:'Life off the mountain at Sigló Hótel.', cat:'Iceland & the Experience' },
  { slug:'how-much-vertical-per-day-heliskiing', h:'How Much Vertical Do You Ski in a Day?', d:'15,000–25,000 feet across 7–14 runs.', cat:'On the Mountain' },
  { slug:'heliski-photography-tips', h:'Heliski Photography Tips', d:'Capture the trip — safely.', cat:'Iceland & the Experience' },
  { slug:'heliskiing-iceland-vs-canada', h:'Iceland vs Canada for Heliskiing', d:'The powder benchmark vs the sea-to-summit.', cat:'Compare & Decide' },
  { slug:'why-iceland-is-a-bucket-list-heliski-destination', h:'Why Iceland Is a Bucket-List Destination', d:'Ski, ocean, light and place.', cat:'Iceland & the Experience' }
];
const collectionLd = {
  "@type": "CollectionPage",
  "name": "Heliskiing in Iceland: The Complete Guide",
  "description": "A ten-chapter guide to heliskiing in Iceland plus fifty in-depth Field Notes articles on destinations, cost, safety, planning and technique worldwide.",
  "url": SITE + "/heliskiing-guide",
  "hasPart": [
    ...chapters.map(c => ({ "@type":"WebPage", "name": c.h, "url": SITE + "/heliskiing-guide/" + c.slug })),
    ...articles.map(a => ({ "@type":"Article", "name": a.h, "url": SITE + "/field-notes/" + a.slug }))
  ]
};
---
<Base
  heroImage="iceland-hero"
  title="Iceland Heliskiing: The Complete Guide (2026) | Heliski Travel"
  description="The complete guide to heliskiing in Iceland — ten expert chapters plus fifty Field Notes articles on destinations, cost, safety, gear, travel and technique."
  active="guide"
  schema={collectionLd}>

<!-- ================= HERO (image only, no text — like the other pages) ================= -->
<section class="gg-hero" id="gg-hero">
  <div class="gg-hero__photo"></div>
  <div class="gg-hero__grade"></div>
  <a class="gg-scroll" href="#gg-intro" aria-label="Scroll to the guide"><span></span></a>
</section>

<!-- ================= INTRO (title lives here) ================= -->
<section class="band band--ink gg-intro" id="gg-intro">
  <div class="shell gg-introwrap">
    <p class="eyebrow">The Complete Guide</p>
    <h1 class="gg-title">Heliskiing<span class="s">in Iceland</span></h1>
    <p class="gg-lede">Ten in-depth chapters plus fifty field notes on Iceland's Tröllaskagi (Troll) Peninsula — sea-to-summit descents from 1,200-metre summits down to the Arctic Ocean. Written by <a href="/about">Heliski&nbsp;Travel</a>, the authorised booking agent for <a href="/packages">Viking&nbsp;Heliskiing</a>.</p>
    <div class="gg-cta">
      <a class="btn" href="#chapters"><span>Explore the guide</span> <span class="arw">&darr;</span></a>
      <a class="btn btn--ghost" href="/packages"><span>View packages</span></a>
    </div>
  </div>
</section>

<!-- ================= CHAPTERS ================= -->
<section class="band band--navy gg-band" id="chapters">
  <div class="shell">
    <div class="gg-split">
      <aside class="gg-aside">
        <p class="eyebrow">The Chapters</p>
        <h2 class="gg-asideh">Ten chapters,<span class="s">start anywhere.</span></h2>
        <p class="gg-asidep">Everything from the terrain and the season to cost, safety, gear and travel — the complete grounding before you book a week on the Troll Peninsula.</p>
        <a class="btn btn--ghost" href="/contact"><span>Request a quote</span></a>
      </aside>

      <div class="gg-rows">
        {chapters.map(c => (
          <a class="gg-r" href={`/heliskiing-guide/${c.slug}`}>
            <span class="gg-r__num">{c.n}</span>
            <span class="gg-r__body">
              <span class="gg-r__h">{c.h}</span>
              <span class="gg-r__p">{c.p}</span>
            </span>
            <span class="gg-r__go">&rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ================= FIELD NOTES (grouped index) ================= -->
<section class="band band--ink gg-band gg-fn" id="field-notes" style="scroll-margin-top:90px;">
  <div class="shell">
    <div class="gg-fnhead">
      <p class="eyebrow">Beyond the Guide · Fifty Articles</p>
      <h2 class="gg-fnh">The Field&nbsp;Notes</h2>
      <p class="gg-fnlede">The wider heliskiing library, sorted by theme — the best destinations in the world, what it costs, how to plan and how to ski it well. Jump straight to what you need.</p>
    </div>

    {catOrder.map(cat => {
      const items = articles.filter(a => a.cat === cat);
      return (
        <div class="gg-grp">
          <div class="gg-grp__head">
            <h3 class="gg-grp__name">{cat}</h3>
            <span class="gg-grp__count">{items.length} articles</span>
          </div>
          <div class="gg-grp__grid">
            {items.map(a => (
              <a class="gg-grp__item" href={`/field-notes/${a.slug}`}>
                <span class="gg-grp__t">{a.h}</span>
                <span class="gg-grp__d">{a.d}</span>
              </a>
            ))}
          </div>
        </div>
      );
    })}

    <div class="gd-cta" style="justify-content:center;border-top:0;margin-top:64px;">
      <a class="btn" href="/packages"><span>View packages</span> <span class="arw">&rarr;</span></a>
      <a class="btn btn--ghost" href="/contact"><span>Request a quote</span></a>
    </div>
  </div>
</section>

<style>
  /* kicker — matches the site's eyebrow */
  .eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
  .eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}

  /* ---- HERO (image only, no text — matches the other pages) ---- */
  .gg-hero{position:relative;min-height:100vh;overflow:hidden;background:var(--navy);}
  .gg-hero__photo{position:absolute;inset:-3%;z-index:0;background:url('/images/iceland-hero.webp') center 38%/cover no-repeat;transform:scale(1.06);animation:ggzoom 9s var(--ease) forwards;}
  @keyframes ggzoom{to{transform:scale(1);}}
  .gg-hero__grade{position:absolute;inset:0;z-index:1;pointer-events:none;
    background:linear-gradient(180deg,rgba(10,22,40,.32) 0%,rgba(10,22,40,0) 20%,rgba(10,22,40,0) 60%,rgba(10,22,40,.5) 82%,var(--ink) 100%),
               linear-gradient(90deg,rgba(10,22,40,.26) 0%,rgba(10,22,40,0) 52%);}
  .gg-scroll{position:absolute;left:50%;bottom:34px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;}
  .gg-scroll span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:ggscroll 1.9s var(--ease) infinite;}
  @keyframes ggscroll{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}

  /* ---- INTRO (title lives here, centred) ---- */
  .gg-intro{padding:clamp(62px,8vw,108px) 0 clamp(54px,7vw,92px);}
  .gg-introwrap{text-align:center;max-width:900px;margin:0 auto;display:flex;flex-direction:column;align-items:center;}
  .gg-intro .eyebrow{justify-content:center;}
  .gg-title{margin:22px 0 0;font-family:var(--serif);font-weight:500;font-size:clamp(3rem,7.5vw,6rem);line-height:.94;letter-spacing:-.015em;color:var(--cream);}
  .gg-title .s{display:block;font-style:italic;font-weight:400;color:var(--blue-soft);}
  .gg-lede{margin:26px auto 0;max-width:60ch;color:rgba(244,246,248,.82);font-size:clamp(15px,1.45vw,18px);line-height:1.72;}
  .gg-lede a{color:var(--blue-soft);text-decoration:none;border-bottom:1px solid var(--cta-line);transition:border-color .4s var(--ease);}
  .gg-lede a:hover{border-color:var(--blue);}
  .gg-cta{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;margin-top:34px;}

  /* ---- band paddings ---- */
  .gg-band{padding:clamp(70px,9vw,128px) 0;}

  /* ---- CHAPTERS: sticky aside + couture numbered rows ---- */
  .gg-split{display:grid;grid-template-columns:320px minmax(0,1fr);gap:clamp(34px,5vw,88px);align-items:start;}
  .gg-aside{position:sticky;top:118px;}
  .gg-asideh{font-family:var(--serif);font-weight:500;font-size:clamp(1.9rem,3vw,2.7rem);line-height:1.02;color:var(--cream);margin:16px 0 18px;}
  .gg-asideh .s{display:block;font-style:italic;font-weight:400;color:var(--blue-soft);}
  .gg-asidep{color:rgba(195,220,238,.66);font-size:15px;line-height:1.7;margin:0 0 28px;max-width:34ch;}

  .gg-rows{border-top:1px solid var(--line);}
  .gg-r{display:grid;grid-template-columns:clamp(56px,6vw,84px) minmax(0,1fr) 28px;align-items:center;gap:clamp(16px,2.4vw,36px);
        padding:clamp(22px,2.8vw,34px) 6px;border-bottom:1px solid var(--line);text-decoration:none;
        transition:padding-left .55s var(--ease),background .55s var(--ease);}
  .gg-r__num{font-family:var(--serif);font-style:italic;font-weight:500;font-size:clamp(30px,4.2vw,48px);line-height:1;color:var(--blue);}
  .gg-r__body{min-width:0;}
  .gg-r__h{display:block;font-family:var(--sans);font-weight:600;font-size:clamp(19px,2.2vw,26px);line-height:1.16;letter-spacing:-.005em;color:var(--cream);transition:color .4s var(--ease);}
  .gg-r__p{display:block;margin-top:7px;color:rgba(244,246,248,.6);font-size:15px;line-height:1.55;max-width:64ch;}
  .gg-r__go{color:var(--blue);font-size:20px;opacity:0;transform:translateX(-8px);transition:opacity .45s var(--ease),transform .45s var(--ease);}
  .gg-r:hover{padding-left:16px;background:linear-gradient(90deg,rgba(168,207,224,.06),transparent 70%);}
  .gg-r:hover .gg-r__h{color:var(--blue-soft);}
  .gg-r:hover .gg-r__go{opacity:1;transform:none;}

  /* ---- FIELD NOTES (grouped index) ---- */
  .gg-fnhead{max-width:62ch;margin:0 0 clamp(44px,5vw,66px);}
  .gg-fnh{font-family:var(--serif);font-weight:500;font-size:clamp(2.3rem,5.2vw,4rem);line-height:1;color:var(--cream);margin:16px 0 0;letter-spacing:-.01em;}
  .gg-fnlede{margin:20px 0 0;color:rgba(195,220,238,.68);font-size:clamp(15px,1.4vw,17px);line-height:1.68;}

  .gg-grp{margin-bottom:clamp(40px,4.4vw,60px);}
  .gg-grp:last-of-type{margin-bottom:0;}
  .gg-grp__head{display:flex;align-items:baseline;gap:18px;padding-bottom:16px;margin-bottom:6px;border-bottom:1px solid var(--line-2);}
  .gg-grp__name{font-family:var(--serif);font-weight:500;font-size:clamp(1.55rem,2.6vw,2.05rem);line-height:1;color:var(--cream);letter-spacing:-.005em;margin:0;}
  .gg-grp__count{font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:var(--blue);font-weight:700;white-space:nowrap;}
  .gg-grp__grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(340px,1fr));gap:0 clamp(30px,4vw,56px);}
  .gg-grp__item{display:block;padding:15px 4px;border-bottom:1px solid var(--line);text-decoration:none;transition:padding-left .45s var(--ease);}
  .gg-grp__t{display:block;font-family:var(--serif);font-weight:500;font-size:clamp(18px,1.5vw,20.5px);line-height:1.16;color:var(--cream);transition:color .4s var(--ease);}
  .gg-grp__d{display:block;font-size:12.5px;color:var(--muted);margin-top:3px;line-height:1.46;}
  .gg-grp__item:hover{padding-left:10px;}
  .gg-grp__item:hover .gg-grp__t{color:var(--blue-soft);}

  @media (max-width:900px){
    .gg-hero{min-height:80vh;}
    .gg-split{grid-template-columns:1fr;gap:26px;}
    .gg-aside{position:static;}
    .gg-asidep{max-width:none;}
  }
  @media (max-width:560px){
    .gg-r{grid-template-columns:clamp(44px,12vw,56px) 1fr;}
    .gg-r__go{display:none;}
  }
  @media (prefers-reduced-motion:reduce){ *{transition:none!important;animation:none!important;} .gg-hero__photo{transform:none;} }
</style>
</Base>
