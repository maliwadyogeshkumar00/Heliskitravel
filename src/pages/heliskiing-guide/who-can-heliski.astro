  <section class="gd-hero">
    <p class="gd-k">The Guide · Chapter 06</p>
    <h1>Who Can Go</h1>
  </section>

  <div class="gd-wrap">
    <aside class="gd-toc">
      <p class="gd-toc-title">On this page</p>
      <nav>
