</style>

<script is:inline>
var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),heroEl=document.getElementById('hero'),hp=document.getElementById('heroPhoto');
var __maxS=0;function __recalc(){__maxS=document.documentElement.scrollHeight-window.innerHeight;}__recalc();window.addEventListener('resize',__recalc,{passive:true});window.addEventListener('load',__recalc);
function onScroll(){var y=window.scrollY,vh=window.innerHeight;hdr.classList.toggle('scrolled',y>40);var h=__maxS;prog.style.width=(h>0?(y/h*100):0)+'%';if(y<vh&&hp){hp.style.transform='translateY('+(y*0.16)+'px) scale(1)';}}
onScroll();window.addEventListener('scroll',onScroll,{passive:true});
requestAnimationFrame(function(){setTimeout(function(){heroEl.classList.add('ready');},140);});

/* mobile menu */
var burger=document.getElementById('burger');function setMenu(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');}
burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});

/* reveal observer */
var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){var sibs=Array.prototype.slice.call(en.target.parentNode.children).filter(function(c){return c.classList.contains('reveal');});en.target.style.transitionDelay=(Math.max(0,sibs.indexOf(en.target))*0.05)+'s';en.target.classList.add('in');io.unobserve(en.target);}});},{threshold:0.06,rootMargin:'0px 0px -4% 0px'});
function observeReveals(scope){(scope||document).querySelectorAll('.reveal:not(.in)').forEach(function(el){io.observe(el);});}
observeReveals(document);

/* PILLS — scroll to section (all content visible) + scroll-spy */
var pills=[].slice.call(document.querySelectorAll('.pill'));
var panels=pills.map(function(p){return document.getElementById('p-'+p.getAttribute('data-tab'));});
function setCur(name){pills.forEach(function(p){var on=p.getAttribute('data-tab')===name;p.classList.toggle('cur',on);p.setAttribute('aria-selected',on?'true':'false');});}
pills.forEach(function(p){p.addEventListener('click',function(){var t=document.getElementById('p-'+p.getAttribute('data-tab'));if(!t)return;var y=t.getBoundingClientRect().top+window.scrollY-130;window.scrollTo({top:y,behavior:'smooth'});setCur(p.getAttribute('data-tab'));
  /* keep the active pill in view inside the scrollable bar */
  p.scrollIntoView({inline:'center',block:'nearest'});});});
var spy=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){setCur(en.target.id.replace('p-',''));}});},{rootMargin:'-45% 0px -50% 0px'});
panels.forEach(function(s){if(s)spy.observe(s);});
</script>
