---
import Base from '../layouts/Base.astro';
const body = `
<section class="legalpage">
  <div class="shell">
    <p class="eyebrow">Legal</p>
    <h1>Imprint</h1>
    <p class="updated">Legal notice · Impressum</p>
    <div class="legal-body">

      <h2>Provider</h2>
      <p>
        <strong>The Alps Experience Travel, Knudsen</strong><br/>
        Entreprise individuelle (sole proprietorship)<br/>
        Nyon, Canton of Vaud, Switzerland
      </p>
      <p>heliskitravel.com is operated by The Alps Experience Travel, Knudsen. &ldquo;Heliski Travel&rdquo; is a trading name of this business.</p>

      <h2>Owner &amp; responsible for content</h2>
      <p>Vegard Knudsen</p>

      <h2>Contact</h2>
      <p>
        Email: <a href="mailto:info@heliskitravel.com">info@heliskitravel.com</a><br/>
        Telephone: +41 79 703 0917 · +47 9412 9999
      </p>

      <h2>Commercial register</h2>
      <p>
        Registered in the Commercial Register of the Canton of Vaud, Switzerland.<br/>
        Business identification number (UID): <strong>CHE-485.511.570</strong>
      </p>

      <h2>Value Added Tax</h2>
      <p>The business is not currently registered for Swiss VAT, as its turnover is below the statutory registration threshold. No VAT is therefore charged on our services.</p>

      <h2>Our role as agent</h2>
      <p>The Alps Experience Travel, Knudsen acts as an official sales agent for <strong>Viking Heliskiing (Iceland)</strong>. The heliskiing itself &mdash; guiding, helicopter access and related mountain services &mdash; is provided and operated by Viking Heliskiing under their own terms and conditions. We arrange and broker your booking; we are not the operator of the heliski service.</p>

      <h2>Disclaimer</h2>
      <p>We prepare the content of this website with care but give no guarantee as to its accuracy, completeness or timeliness. Heliskiing and related services are provided by our partner operator Viking Heliskiing and are subject to their own terms. Heliskiing is an alpine activity that depends on weather and snow conditions; flying days cannot be guaranteed. Where this site links to external websites, we are not responsible for their content.</p>

      <h2>Copyright</h2>
      <p>All content, text, images and design on this website are protected by copyright. Photography and film are used with the permission of the respective owners. Any use beyond what copyright law permits requires our prior written consent.</p>

      <p>See also our <a href="/privacy-policy">Privacy Policy</a>, <a href="/terms">Terms &amp; Conditions</a> and <a href="/cookie-policy">Cookie Policy</a>.</p>
    </div>
  </div>
</section>
`;
---
<Base title="Imprint | Heliski Travel" description="Legal notice and provider information for heliskitravel.com, operated by The Alps Experience Travel, Knudsen — authorised sales agent for Viking Heliskiing, Iceland." active="">
  <Fragment set:html={body} />
  <script is:inline>
    (function(){var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),burger=document.getElementById('burger');
      var __maxS=0;function __recalc(){__maxS=document.documentElement.scrollHeight-window.innerHeight;}__recalc();window.addEventListener('resize',__recalc,{passive:true});window.addEventListener('load',__recalc);
function onScroll(){var y=window.scrollY,vh=window.innerHeight;if(hdr)hdr.classList.toggle('scrolled',y>40);if(prog){var h=__maxS;prog.style.width=(h>0?(y/h*100):0)+'%';}}
      onScroll();window.addEventListener('scroll',onScroll,{passive:true});
      if(burger){var setMenu=function(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');};
        burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
        document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});}
    })();
  </script>
</Base>
