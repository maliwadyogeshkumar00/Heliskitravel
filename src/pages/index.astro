slides.forEach(function(s,i){var b=document.createElement('button');b.className='dot'+(i===0?' on':'');b.setAttribute('aria-label','Slide '+(i+1));b.addEventListener('click',function(){go(i);reset();});dotsWrap.appendChild(b);});
var dots=dotsWrap?[].slice.call(dotsWrap.children):[];
var swapping=false;
function go(n){var nx=((n%slides.length)+slides.length)%slides.length;if(swapping||nx===idx)return;swapping=true;slides[idx].classList.remove('on');dots[idx].classList.remove('on');if(bgs[idx])bgs[idx].classList.remove('on');if(bgs[nx])bgs[nx].classList.add('on');dots[nx].classList.add('on');setTimeout(function(){idx=nx;slides[idx].classList.add('on');swapping=false;},470);}
