---
import Base from '../layouts/Base.astro';
const videoLd = {
  "@type": "VideoObject",
  "name": "Heliskiing in Iceland — Aerial Teaser",
  "description": "Aerial film of heliskiing on the Tröllaskagi (Troll) Peninsula, North Iceland — a helicopter accessing Arctic peaks that rise straight from the sea, with powder descents to the fjord.",
  "thumbnailUrl": "https://heliskitravel.vercel.app/videos/heli-poster.jpg",
  "uploadDate": "2026-07-01",
  "duration": "PT26S",
  "contentUrl": "https://heliskitravel.vercel.app/videos/heli-teaser-hd-a2.mp4"
};
const body = `

<!-- HERO SLIDER -->
<section class="hero" id="hero">
  <div class="soundctl" id="soundCtl"><button id="soundToggle" class="stbtn on" type="button" aria-label="Mute sound" aria-pressed="true"><svg viewBox="0 0 24 24" width="17" height="17" aria-hidden="true"><path d="M4 9v6h4l5 5V4L8 9H4z" fill="currentColor"/><path class="st__w1" d="M16 8.5a4.5 4.5 0 010 7" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><path class="st__w2" d="M18.7 6a8 8 0 010 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/><line class="st__slash" x1="3.5" y1="3.5" x2="20.5" y2="20.5" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg></button><input id="heroVol" class="stvol" type="range" min="0" max="100" value="25" step="1" aria-label="Volume" /></div>
  <div class="hero__photo" id="heroPhoto"></div>
  <video class="hero__video" autoplay muted loop playsinline preload="none" poster="/videos/heli-poster.webp" data-desktop="/videos/heli-teaser-hd-a2.mp4" data-mobile="/videos/heli-mobile-hd-a2.mp4" data-poster-mobile="/videos/heli-poster-mobile.webp"><track kind="captions" src="/videos/empty.vtt" srclang="en" label="No dialogue" /></video>
  {/* LQIP blur-up: inline data-URI placeholder paints instantly (0 network) and is the LCP element.
      It blurs up to the sharp poster (same frame), which then dissolves into the playing video. */}
  <picture class="hero__lqip" id="heroLqip" aria-hidden="true">
    <source media="(max-width: 767px)" srcset="data:image/webp;base64," />
    <img src="data:image/webp;base64," alt="" fetchpriority="high" decoding="async" width="1920" height="1080" />
  </picture>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" href="#" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell">
    <h1 class="sr-only">Heliski Travel — Heliskiing in Iceland with Viking Heliskiing</h1>
  </div>
</section>

<!-- TRUST STRIP -->
<div class="trust"><div class="shell reveal">
  <div class="t"><span class="k">Authorised Agent</span><span class="v">Viking Heliskiing, Iceland</span></div>
  <div class="t"><span class="k">Northernmost Base</span><span class="v">Siglufjörður · Troll Peninsula</span></div>
  <div class="t"><span class="k">IFMGA Guides</span><span class="v">Fully certified, every run</span></div>
  <div class="t"><span class="k">12-Hour Reply</span><span class="v">A person, not a bot</span></div>
</div></div>

<!-- FOUR NUMBERED CARDS -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Experiences</p>
      <h2 class="sectit">Four ways to ride <span class="s">Iceland's Arctic.</span></h2>
    </div>
    <div class="qcards reveal">
      <a class="qcard" href="/heli-assisted-touring" style="--img:url('/images/gallery/heliskiers-sunset-arctic-ocean-iceland.jpg')" aria-label="Heli-Assist">
        <span class="nx">01</span>
        <div class="qc__body"><h3>Heli-Assist</h3><p>Ski touring with helicopter uplift. Access Iceland's most remote terrain without leaving the touring ethos behind.</p><span class="go">Explore Heli-Assist <span class="arw">→</span></span></div>
      </a>
      <a class="qcard" href="/packages" style="--img:url('/images/gallery/helicopter-cockpit-view-iceland-peaks.jpg')" aria-label="Classic Heliskiing">
        <span class="nx">02</span>
        <div class="qc__body"><h3>Classic Heliskiing</h3><p>Group packages with Viking Heliskiing — multiple daily runs through Iceland's most spectacular untracked terrain.</p><span class="go">See Packages <span class="arw">→</span></span></div>
      </a>
      <a class="qcard" href="/private-heliskiing" style="--img:url('/images/gallery/heliski-guides-ridge-sunset-iceland.jpg')" aria-label="Private Heliskiing">
        <span class="nx">03</span>
        <div class="qc__body"><h3>Private Heliskiing</h3><p>Exclusive helicopter hire for your group. Your terrain, your schedule, your pace. The ultimate Arctic experience.</p><span class="go">Begin Inquiry <span class="arw">→</span></span></div>
      </a>
      <a class="qcard" href="/contact" style="--img:url('/images/gallery/heliski-mountain-field-lunch-iceland.jpg')" aria-label="Contact Us">
        <span class="nx">04</span>
        <div class="qc__body"><h3>Contact Us</h3><p>Ready to plan? Get in touch for availability, pricing, and bespoke itinerary advice from our team.</p><span class="go">Get In Touch <span class="arw">→</span></span></div>
      </a>
    </div>
  </div>
</section>

<!-- THREE QUICK LINKS -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Plan Your Trip</p>
      <h2 class="sectit">Everything <span class="s">around the skiing.</span></h2>
    </div>
    <div class="plan reveal">
      <a class="prow" href="/iceland"><span class="pk plab">The Guide</span><span class="pt">How to Get There</span><img class="pthumb" src="/images/wp/DJI_0806.webp" alt="How to get there" loading="lazy" decoding="async" width="118" height="76"/><span class="pgo">→</span></a>
      <a class="prow" href="/siglo-hotel"><span class="pk plab">Your Basecamp</span><span class="pt">Sigló Hotel</span><img class="pthumb" src="/_vercel/image?url=https%3A%2F%2Fheliskitravel.com%2Fwp-content%2Fuploads%2F2026%2F05%2FSiglo-Hotel-1024x780.webp&amp;w=1200&amp;q=72" srcset="/_vercel/image?url=https%3A%2F%2Fheliskitravel.com%2Fwp-content%2Fuploads%2F2026%2F05%2FSiglo-Hotel-1024x780.webp&amp;w=640&amp;q=72 640w, /_vercel/image?url=https%3A%2F%2Fheliskitravel.com%2Fwp-content%2Fuploads%2F2026%2F05%2FSiglo-Hotel-1024x780.webp&amp;w=1080&amp;q=72 1080w, /_vercel/image?url=https%3A%2F%2Fheliskitravel.com%2Fwp-content%2Fuploads%2F2026%2F05%2FSiglo-Hotel-1024x780.webp&amp;w=1200&amp;q=72 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel" loading="lazy" decoding="async" width="118" height="76"/><span class="pgo">→</span></a>
      <a class="prow" href="/contact"><span class="pk plab">Get in Touch</span><span class="pt">Enquire Now</span><img class="pthumb" src="/images/wp/004.webp" alt="Enquire now" loading="lazy" decoding="async" width="118" height="76"/><span class="pgo">→</span></a>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section class="band band--ink">
  <div class="shell about">
    <div class="reveal">
      <p class="eyebrow">Authorised Agent · Viking Heliskiing Iceland</p>
      <h2 class="sectit" style="font-size:clamp(30px,3.8vw,48px);margin-bottom:24px;">The world's most dramatic <span class="s">heliski destination.</span></h2>
      <p class="lead">Heliskitravel.com is your specialist booking partner for Viking Heliskiing, operating from Siglufjörður in northern Iceland — the world's northernmost heliski destination. With over a decade of alpine expertise and deep knowledge of Scandinavian mountain culture, we offer a personal, knowledgeable booking experience matched to none.</p>
      <a class="lnk" href="/iceland">How to reach Siglufjörður <span class="arw">→</span></a>
    </div>
    <div class="imgw reveal"><img src="/images/wp/heli_-6.webp" alt="Helicopter on the Troll Peninsula" loading="lazy" decoding="async" width="800" height="600"/></div>
  </div>
</section>

<!-- FOOTER -->
`;
---
<Base title="Heliski Travel Iceland | Trusted Heliskiing Travel Agent" description="World-class heliskiing in Iceland with Heliskitravel.com — authorised Viking Heliskiing agent, IFMGA-certified guides, Arctic powder, reply within 12 hours." active="home" schema={videoLd}>
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/wp/004.webp");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--serif);font-weight:500;letter-spacing:-.005em;font-size:clamp(38px,5.4vw,64px);line-height:1.04;color:var(--cream);margin:18px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.02em;line-height:1.02;letter-spacing:0;}
.intro{margin:26px 0 0;color:rgba(244,246,248,0.68);font-size:17px;line-height:1.82;max-width:62ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,0.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,0.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}.submenu{position:static;opacity:1;visibility:visible;transform:none;background:none;border:0;box-shadow:none;padding:4px 0 2px 16px;margin:0;min-width:0;}.submenu::before{display:none;}.submenu a{padding:10px 0;font-size:15px;text-transform:none;letter-spacing:.04em;color:rgba(244,246,248,0.7);}}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}

/* HERO slider (4 slides, each its own CTA) */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;padding:118px 0 96px;overflow:hidden;background:var(--ink);}
.hero__photo{position:absolute;inset:-2%;z-index:0;background:#0A1628 url('/videos/heli-poster.webp') center 40%/cover no-repeat;transform:scale(1.04);}
@media(max-width:767px){.hero__photo{background-image:url('/videos/heli-poster-mobile.webp');}}
.hero__video{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;opacity:0;transition:opacity 1.5s var(--ease);}
.hero.ready .hero__video{opacity:1;}
/* LQIP blur-up placeholder — instant inline paint (LCP), dissolves once the sharp poster has decoded */
.hero__lqip{position:absolute;inset:0;z-index:0;pointer-events:none;}
.hero__lqip img{width:100%;height:100%;object-fit:cover;object-position:center 40%;filter:blur(20px);transform:scale(1.12);opacity:1;transition:opacity 1s var(--ease);will-change:opacity;}
.hero.poster-ready .hero__lqip img{opacity:0;}
@media(prefers-reduced-motion:reduce){.hero__lqip img{transition:none;}}
.soundctl{position:fixed;left:22px;bottom:22px;z-index:60;display:inline-flex;align-items:center;gap:11px;padding:9px 15px 9px 13px;border-radius:999px;border:1px solid var(--cta-line);background:rgba(10,22,40,.4);backdrop-filter:blur(9px);-webkit-backdrop-filter:blur(9px);color:var(--cream);transition:background .3s var(--ease),border-color .3s var(--ease);}
.soundctl:hover{background:rgba(10,22,40,.62);border-color:var(--blue-soft);}
.stbtn{flex:0 0 auto;display:inline-flex;align-items:center;justify-content:center;background:none;border:0;padding:0;color:var(--cream);cursor:pointer;line-height:0;}
.stbtn .st__w1,.stbtn .st__w2{opacity:0;transition:opacity .3s;}
.stbtn .st__slash{opacity:1;transition:opacity .3s;}
.stbtn.on .st__slash{opacity:0;}
.stbtn.on .st__w1{opacity:1;}
.stbtn.on .st__w2{opacity:.55;}
.stvol{-webkit-appearance:none;appearance:none;width:82px;height:3px;border-radius:3px;background:rgba(195,220,238,.32);cursor:pointer;outline:none;}
.stvol::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:13px;height:13px;border-radius:50%;background:var(--cream);border:0;cursor:pointer;box-shadow:0 1px 4px rgba(0,0,0,.4);}
.stvol::-moz-range-thumb{width:13px;height:13px;border-radius:50%;background:var(--cream);border:0;cursor:pointer;}
.stvol:focus-visible{outline:2px solid var(--blue-soft);outline-offset:4px;}
@media(max-width:767px){.soundctl{left:16px;bottom:16px;padding:8px 13px 8px 11px;gap:9px;}.stvol{width:66px;}}
.hero .grade{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,22,40,.5) 0%,rgba(10,22,40,0) 20%,rgba(10,22,40,0) 60%,rgba(10,22,40,.5) 86%,var(--ink) 100%);}
.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;}
.harrow{position:absolute;top:50%;transform:translateY(-50%);z-index:5;width:54px;height:54px;border:1px solid var(--cta-line);border-radius:50%;display:flex;align-items:center;justify-content:center;color:var(--cream);background:rgba(10,22,40,.22);backdrop-filter:blur(6px);-webkit-backdrop-filter:blur(6px);font-size:24px;line-height:1;cursor:pointer;padding:0 0 3px;opacity:0;transition:opacity 1s var(--ease) 1s,background .4s var(--ease),border-color .4s var(--ease);}
.hero.ready .harrow{opacity:1;}
.harrow:hover{background:rgba(10,22,40,.5);border-color:var(--blue);}
.harrow--prev{left:38px;}.harrow--next{right:38px;}
.hero .shell{position:relative;z-index:3;}
.scrolldn{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;opacity:0;transition:opacity 1s var(--ease) 1.4s;}
.hero.ready .scrolldn{opacity:1;}
.scrolldn span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:scrolldn 1.9s var(--ease) infinite;}
@keyframes scrolldn{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}
.hero .eyebrow{margin-bottom:24px;animation:heroIn 1s var(--ease) .35s both;}
.hero__in{max-width:780px;}
.hero__h1{margin:0;font-family:var(--serif);font-weight:500;letter-spacing:-.005em;font-size:clamp(42px,6.4vw,90px);line-height:1.0;color:var(--cream);text-shadow:0 3px 44px rgba(10,22,40,.55);}
.hero__h1 em{font-style:italic;font-weight:500;color:var(--blue-soft);}
.hero__sub{margin:26px 0 0;max-width:46ch;color:rgba(244,246,248,0.88);font-size:clamp(16px,1.35vw,19px);line-height:1.72;text-shadow:0 2px 20px rgba(10,22,40,.55);}
.hero__cta{display:flex;flex-wrap:wrap;gap:15px;margin-top:38px;}
.hero__h1{animation:heroIn 1s var(--ease) .5s both;}
.hero__sub{animation:heroIn 1s var(--ease) .68s both;}
.hero__cta{animation:heroIn 1s var(--ease) .86s both;}
@keyframes heroIn{from{transform:translateY(16px);}to{transform:none;}}
.slides{position:relative;min-height:clamp(360px,48vh,470px);max-width:760px;}
.slide{position:absolute;inset:0;opacity:0;transform:translateY(16px);transition:opacity .55s var(--ease),transform .7s var(--ease);pointer-events:none;}
.slide.on{opacity:1;transform:none;pointer-events:auto;}
.slide h2{margin:0;font-family:var(--serif);font-weight:600;letter-spacing:-.005em;font-size:clamp(42px,5.8vw,84px);line-height:1.0;color:var(--cream);text-shadow:0 3px 44px rgba(10,22,40,.55);}
.slide h2 em{font-style:italic;font-weight:500;color:var(--blue-soft);}
.slide p{margin:24px 0 0;max-width:46ch;color:rgba(244,246,248,0.9);font-size:clamp(16px,1.35vw,18.5px);line-height:1.72;text-shadow:0 2px 18px rgba(10,22,40,.55);}
.slide .btn{margin-top:34px;}
.dots{position:relative;z-index:3;display:flex;gap:10px;margin-top:34px;}
.dot{width:30px;height:3px;border-radius:2px;background:rgba(195,220,238,.3);border:0;cursor:pointer;padding:0;transition:background .4s var(--ease);}
.dot.on{background:var(--blue);}

/* trust strip */
.trust{background:var(--navy);border-top:1px solid var(--line);border-bottom:1px solid var(--line);}
.trust .shell{display:grid;grid-template-columns:repeat(4,1fr);gap:0;padding:0;}
.trust .t{display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;gap:9px;padding:42px 28px;border-left:1px solid var(--line);transition:background .6s var(--ease);}
.trust .t:first-child{border-left:0;}
.trust .t:hover{background:rgba(168,207,224,.035);}
.trust .k{font-family:var(--serif);font-style:italic;font-weight:500;font-size:24px;line-height:1;color:var(--cream);letter-spacing:.01em;transition:color .5s var(--ease);}
.trust .t:hover .k{color:var(--blue-soft);}
.trust .v{font-size:9.5px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,0.66);}

.band{padding:118px 0;}
.band--ink{background:var(--ink);}.band--navy{background:var(--navy);}
.head{max-width:840px;margin:0 0 56px;}

/* four numbered cards (01-04) */
.qcards{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;}
.qcard{position:relative;display:block;aspect-ratio:3/4.2;border-radius:12px;overflow:hidden;background:var(--navy);box-shadow:inset 0 0 0 1px rgba(138,180,204,.1);transition:box-shadow .5s var(--ease),transform .5s var(--ease);}
.qcard::before{content:"";position:absolute;inset:0;z-index:0;background:var(--img) center/cover no-repeat;transform:scale(1.02);transition:transform 1.2s var(--ease);}
.qcard::after{content:"";position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,22,40,.12) 0%,rgba(10,22,40,0) 32%,rgba(10,22,40,.55) 66%,rgba(10,22,40,.9) 100%);transition:background .5s var(--ease);}
.qcard:hover{box-shadow:inset 0 0 0 1px rgba(168,207,224,.4);transform:translateY(-4px);}
.qcard:hover::before{transform:scale(1.09);}
.qcard:hover::after{background:linear-gradient(180deg,rgba(10,22,40,.22) 0%,rgba(10,22,40,.08) 26%,rgba(10,22,40,.72) 60%,rgba(10,22,40,.95) 100%);}
.qcard .nx{position:absolute;top:24px;left:26px;z-index:2;font-family:var(--serif);font-style:italic;font-size:30px;color:var(--blue-soft);text-shadow:0 2px 22px rgba(10,22,40,.7);}
.qc__body{position:absolute;left:0;right:0;bottom:0;z-index:2;padding:26px 26px 28px;}
.qcard h3{margin:0;font-family:var(--sans);font-weight:600;font-size:22px;line-height:1.12;letter-spacing:-.01em;color:var(--cream);text-shadow:0 2px 18px rgba(10,22,40,.55);}
.qcard p{margin:0;max-height:0;opacity:0;overflow:hidden;color:rgba(244,246,248,0.85);font-size:13.5px;line-height:1.6;transition:max-height .55s var(--ease),opacity .5s var(--ease),margin .55s var(--ease);}
.qcard:hover p,.qcard:focus-visible p{max-height:140px;opacity:1;margin:13px 0 0;}
.qcard .go{display:inline-flex;align-items:center;gap:10px;margin-top:16px;font-size:10.5px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--blue-soft);transition:color .4s var(--ease);}
.qcard:hover .go{color:var(--cream);}
.qcard .go .arw{transition:transform .5s var(--ease);}.qcard:hover .go .arw{transform:translateX(6px);}
@media(hover:none){.qcard p{max-height:140px;opacity:1;margin:13px 0 0;}}

/* three big quick links */
.bigl{display:grid;grid-template-columns:repeat(3,1fr);gap:18px;}
.bl{position:relative;aspect-ratio:3/4;border-radius:6px;overflow:hidden;display:flex;align-items:flex-end;background:var(--panel);}
.bl img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 1.1s var(--ease);}
.bl::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(10,22,40,.12),rgba(10,22,40,.8));}
.bl:hover img{transform:scale(1.06);}
.bl .lbl{position:relative;z-index:1;padding:34px 30px;width:100%;}
.bl .lbl .k{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:var(--blue-soft);}
.bl .lbl h3{margin:8px 0 0;font-family:var(--serif);font-style:italic;font-weight:400;font-size:30px;color:var(--cream);display:flex;align-items:center;gap:14px;}
.bl .lbl .arw{transition:transform .5s var(--ease);}.bl:hover .lbl .arw{transform:translateX(6px);}

/* plan-your-trip — vertical-rule split index rows */
.plan .prow{display:grid;grid-template-columns:210px 1fr 118px auto;align-items:center;gap:36px;padding:30px 12px;border-top:1px solid var(--line);transition:background .5s var(--ease);}
.plan .prow:last-child{border-bottom:1px solid var(--line);}
.plan .prow:hover{background:rgba(168,207,224,.03);}
.plan .plab{border-right:1px solid var(--line-2);padding-right:32px;font-size:10.5px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);}
.plan .pt{font-family:var(--serif);font-style:italic;font-weight:500;font-size:clamp(26px,2.9vw,37px);line-height:1;color:var(--cream);transition:color .5s var(--ease);}
.plan .prow:hover .pt{color:var(--blue-soft);}
.plan .pthumb{width:118px;height:76px;border-radius:5px;object-fit:cover;}
.plan .pgo{font-size:22px;color:var(--blue);justify-self:end;transition:transform .5s var(--ease),color .5s var(--ease);}
.plan .prow:hover .pgo{transform:translateX(8px);color:var(--blue-soft);}
@media(max-width:900px){
  .plan .prow{grid-template-columns:1fr auto;grid-template-rows:auto auto;column-gap:16px;row-gap:5px;padding:24px 6px;}
  .plan .plab{border-right:0;padding-right:0;grid-column:1;grid-row:1;}
  .plan .pt{grid-column:1;grid-row:2;font-size:26px;}
  .plan .pthumb{display:none;}
  .plan .pgo{grid-column:2;grid-row:1 / span 2;align-self:center;}
}

/* about split */
.about{display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,6vw,84px);align-items:center;}
.about .imgw{aspect-ratio:4/3;border-radius:6px;overflow:hidden;background:var(--panel);}
.about .imgw img{width:100%;height:100%;object-fit:cover;}
.about p{color:rgba(244,246,248,0.72);font-size:16.5px;line-height:1.84;margin:0 0 20px;}
.about .lead{font-family:var(--sans);font-size:17px;line-height:1.85;color:rgba(244,246,248,0.74);margin:0 0 30px;}
.about .lead::first-letter{float:left;font-family:var(--serif);font-style:italic;font-weight:500;font-size:78px;line-height:.72;color:var(--blue-soft);padding:9px 16px 0 0;}
.about .eyebrow{font-size:9.5px;letter-spacing:.2em;gap:12px;}
.about .eyebrow::before{width:24px;}
.about .lnk{display:inline-flex;align-items:center;gap:12px;margin-top:8px;font-size:11px;font-weight:600;letter-spacing:.2em;text-transform:uppercase;color:var(--cream);}
.about .lnk .arw{transition:transform .5s var(--ease);}.about .lnk:hover .arw{transform:translateX(6px);}

.btn{display:inline-flex;align-items:center;gap:14px;cursor:pointer;background:transparent;border:1px solid var(--cta-line);border-radius:var(--radius);color:var(--cream);font-family:inherit;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;padding:17px 42px;position:relative;overflow:hidden;transition:border-color .6s var(--ease);}
.btn::before{content:"";position:absolute;inset:0;background:rgba(168,207,224,.12);transform:scaleX(0);transform-origin:left;transition:transform .6s var(--ease);}
.btn span{position:relative;z-index:1;}.btn .arw{position:relative;z-index:1;transition:transform .6s var(--ease);}
.btn:hover{border-color:rgba(168,207,224,.8);}.btn:hover::before{transform:scaleX(1);}.btn:hover .arw{transform:translateX(6px);}
.btn--solid{background:var(--blue);border-color:var(--blue);color:var(--ink);}.btn--solid::before{background:rgba(255,255,255,.18);}

.sf{background:var(--ink);border-top:1px solid var(--line);}
.sf .shell{padding:60px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:62px;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
.sf__nav a{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,246,248,0.72);}.sf__nav a:hover{color:var(--blue-soft);}
.sf__mid{text-align:center;border-top:1px solid var(--line);padding:58px 0 0;}
.sf__mid .big{font-family:var(--serif);font-style:italic;font-size:clamp(30px,5.6vw,72px);color:var(--cream);}
.sf__trust{margin:34px 0 56px;text-align:center;font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,0.66);}
.sf__trust b{font-weight:600;color:var(--blue-soft);}
.sf__base{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px;}
.sf__base .cr{font-size:11px;color:rgba(244,246,248,0.62);}
.sf__base a{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(168,207,224,.72);}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s var(--ease),transform .9s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media (prefers-reduced-motion:reduce){.reveal,.hero__photo,.hero__video,.hero .eyebrow,.hero__h1,.hero__sub,.hero__cta{opacity:1!important;transform:none!important;transition:none!important;animation:none!important;}*{scroll-behavior:auto!important;}}

@media(max-width:1080px){.qcards{grid-template-columns:1fr 1fr;}}
@media(max-width:980px){.trust .shell{grid-template-columns:1fr 1fr;}.trust .t:nth-child(3){border-left:0;}.trust .t:nth-child(n+3){border-top:1px solid var(--line);}.about{grid-template-columns:1fr;}.about .imgw{order:-1;}.bigl{grid-template-columns:1fr;}.bl{aspect-ratio:16/9;}}
@media(max-width:900px){
  .shell{padding:0 24px;}.burger{display:flex;}
  .menu{position:fixed;top:0;right:0;bottom:0;width:min(80vw,360px);background:rgba(10,22,40,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px 36px;transform:translateX(100%);transition:transform .6s var(--ease);}
  body.nav-open .menu{transform:none;}
  .menu a{font-size:18px;letter-spacing:.06em;text-transform:none;padding:14px 0;color:var(--cream);}.menu a::after{display:none;}
  .hero{min-height:92vh;padding-bottom:60px;}
  .trust .shell{grid-template-columns:1fr;}.trust .t{border-left:0;padding:30px 24px;}.trust .t:not(:first-child){border-top:1px solid var(--line);}
  .band{padding:76px 0;}
  .qcards{grid-template-columns:1fr;}
  .qcard{aspect-ratio:16/11;}
  .sf__top,.sf__base{flex-direction:column;align-items:flex-start;gap:14px;}
}
@media(max-width:560px){.eyebrow{flex-wrap:wrap;letter-spacing:.2em;}}
</style>

<script is:inline>
/* hero video: poster is the LCP; defer the video download until after load so it never competes with first paint */
/* LQIP blur-up: dissolve the inline placeholder once the sharp poster has decoded (stage 2 of 3) */
(function(){var hero=document.getElementById('hero');if(!hero)return;var m=window.matchMedia('(max-width:767px)').matches;var poster=m?'/videos/heli-poster-mobile.webp':'/videos/heli-poster.webp';var done=false;function reveal(){if(done)return;done=true;hero.classList.add('poster-ready');}var im=new Image();im.onload=reveal;im.onerror=reveal;im.src=poster;if(im.complete)reveal();setTimeout(reveal,2500);})();
/* Progressive quality ramp (ABR-lite): poster is instant, then a light tier starts fast, then it
