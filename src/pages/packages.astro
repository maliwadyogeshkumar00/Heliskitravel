---
import Base from '../layouts/Base.astro';
const body = `

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__photo" id="heroPhoto"></div>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" href="#" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell"><h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Heliskiing Packages — Iceland</h1></div>
</section>

<!-- INTRO + CARDS -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Choose your week</p>
      <h2 class="sectit">One mountain,<span class="s">three ways to ride it.</span></h2>
      <p class="intro">Every package is a 3, 4 or 5-day week based at Sigló Hotel, guided by IFMGA-certified guides, with K2 gear and full board included. The only question is how you want to reach the top.</p>
    </div>
    <div class="pcards">
      <a class="pcard reveal" href="/classic-heliskiing">
        <div class="pcard__img"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/JRJ06349-1024x683.webp" alt="Classic Heliskiing" loading="lazy"/></div>
        <div class="pcard__body">
          <span class="num">I.</span>
          <span class="plabel">Package One</span>
          <h3 class="pname">Classic <em>Heliskiing.</em></h3>
          <p class="ptag">For skiers who want maximum descents — all helicopter, no climbing.</p>
          <p class="pdesc">The full helicopter week. Powder, spring corn, and exposed Arctic lines from summit to ocean. Around 15,000 vertical feet on the right day, with the mountain setting the pace.</p>
          <div class="pmeta">
            <div class="mr"><span class="mk">Days &amp; Pricing</span><span class="mv">3 / 4 / 5 day weeks · from €6,790</span></div>
            <div class="mr"><span class="mk">Group Size</span><span class="mv">4 skiers, 1 mountain guide</span></div>
            <div class="mr"><span class="mk">Vertical</span><span class="mv">45,000 – 75,000 ft of skiing per week</span></div>
            <div class="mr"><span class="mk">Included</span><span class="mv">Sigló Hotel · full board · K2 setup · après-ski</span></div>
          </div>
          <span class="pbtn">Explore Classic <span class="arw">→</span></span>
        </div>
      </a>
      <a class="pcard pop reveal" href="/heli-assisted-touring">
        <div class="pcard__img"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/Drone-2-1024x576.webp" alt="Heli-Assisted Touring" loading="lazy"/><span class="pop__tag">Most Popular</span></div>
        <div class="pcard__body">
          <span class="num">II.</span>
          <span class="plabel">Package Two</span>
          <h3 class="pname">Heli-Assisted <em>touring.</em></h3>
          <p class="ptag">For those who love to earn their turns — the freedom of touring, the reach of the rotor.</p>
          <p class="pdesc">The hybrid week. Two helicopter lifts and two skinned ascents every day — the adventure of touring with helicopter access to terrain you'd never reach on foot, and more runs when conditions allow.</p>
          <div class="pmeta">
            <div class="mr"><span class="mk">Days &amp; Pricing</span><span class="mv">3 / 4 / 5 day weeks · from €3,490</span></div>
            <div class="mr"><span class="mk">Group Size</span><span class="mv">4 skiers, 1 mountain guide</span></div>
            <div class="mr"><span class="mk">A Typical Day</span><span class="mv">2 heli lifts, 2 ascents, 4 descents · lunch in the field</span></div>
            <div class="mr"><span class="mk">Included</span><span class="mv">Sigló Hotel · full board · K2 setup · après-ski</span></div>
          </div>
          <span class="pbtn pbtn--solid">Explore Heli-Assisted <span class="arw">→</span></span>
        </div>
      </a>
      <a class="pcard reveal" href="/private-heliskiing">
        <div class="pcard__img"><img src="https://heliskitravel.com/wp-content/uploads/2026/05/DJI_0806-1024x767.webp" alt="Private Heliskiing" loading="lazy"/></div>
        <div class="pcard__body">
          <span class="num">III.</span>
          <span class="plabel">Package Three</span>
          <h3 class="pname">Private <em>Heliskiing.</em></h3>
          <p class="ptag">For those who want the mountain entirely to themselves.</p>
          <p class="pdesc">The exclusive week. A dedicated helicopter and private guide, entirely on your terms. Choose your lines, set your pace, and fly when you want. The mountain, yours alone.</p>
          <div class="pmeta">
            <div class="mr"><span class="mk">Days &amp; Pricing</span><span class="mv">3 / 4 / 5 day weeks · price on request</span></div>
            <div class="mr"><span class="mk">Season</span><span class="mv">March 10 to mid-May</span></div>
            <div class="mr"><span class="mk">Terrain</span><span class="mv">Couloirs, alpine bowls, peak-to-ocean</span></div>
            <div class="mr"><span class="mk">Included</span><span class="mv">Sigló Hotel · full board · K2 setup · après-ski</span></div>
          </div>
          <span class="pbtn">Explore Private <span class="arw">→</span></span>
        </div>
      </a>
    </div>
  </div>
</section>

<!-- ELEVEN ZONES -->
<section class="band band--navy">
  <div class="shell zones__grid">
    <div class="zones__img reveal"><img src="https://heliskitravel.com/wp-content/uploads/2026/06/vegard_map.jpg" alt="Viking Heliskiing zones map across the Troll Peninsula" loading="lazy"/></div>
    <div class="reveal">
      <p class="eyebrow">On the ground in Siglufjörður</p>
      <h2 class="zones__h">Eleven zones across the Troll Peninsula</h2>
      <p class="zones__p">Every week is flown across our home terrain in North Iceland — eleven mapped heliskiing zones rising straight from the Arctic sea, scouted and guided by the Viking Heliskiing team.</p>
      <p class="zones__p">Whichever package you choose, this is where your week takes shape.</p>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta">
  <div class="shell">
    <p class="eyebrow">Reserve a week</p>
    <h2>Not sure which week? <span class="s">We'll help you choose.</span></h2>
    <div><a class="btn" href="/contact"><span>Request a consultation</span> <span class="arw">→</span></a></div>
  </div>
</section>

<!-- FOOTER -->
`;
---
<Base title="Heliskiing Packages Iceland: Classic, Heli-Assisted & Private | Heliski Travel" description="Three ways to ski the Troll Peninsula: Classic Heliskiing, Heli-Assisted Touring, and Private Heliskiing. 3–5 day weeks at Sigló Hotel with IFMGA guides." active="packages">
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"proxima-nova","Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/packages-hero.jpg");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--sans);font-weight:600;letter-spacing:-.015em;font-size:clamp(34px,5vw,60px);line-height:1.02;color:var(--cream);margin:22px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.04em;line-height:1;letter-spacing:0;}
.intro{margin:26px 0 0;color:rgba(244,246,248,.68);font-size:17px;line-height:1.82;max-width:64ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}.submenu{position:static;opacity:1;visibility:visible;transform:none;background:none;border:0;box-shadow:none;padding:4px 0 2px 16px;margin:0;min-width:0;}.submenu::before{display:none;}.submenu a{padding:10px 0;font-size:15px;text-transform:none;letter-spacing:.04em;color:rgba(244,246,248,.7);}}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}

.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding:0 0 96px;overflow:hidden;background:var(--navy);}
.hero__photo{position:absolute;inset:-3%;z-index:0;background:var(--hero) center 40%/cover no-repeat;opacity:0;transform:scale(1.08);transition:opacity 1.8s var(--ease),transform 2.4s var(--ease);}
.hero.ready .hero__photo{opacity:1;transform:scale(1);}
.hero .grade{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(180deg,rgba(10,22,40,0.34) 0%,rgba(10,22,40,0) 22%),linear-gradient(90deg,rgba(10,22,40,0.16) 0%,rgba(10,22,40,0) 52%);}
.hero .shell{position:relative;z-index:3;}
.scrolldn{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;opacity:0;transition:opacity 1s var(--ease) 1.4s;}
.hero.ready .scrolldn{opacity:1;}
.scrolldn span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:scrolldn 1.9s var(--ease) infinite;}
@keyframes scrolldn{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}
.hero .eyebrow{margin-bottom:26px;opacity:0;transform:translateY(12px);transition:opacity 1s var(--ease) .5s,transform 1s var(--ease) .5s;}
.hero .big{margin:0;font-family:var(--sans);font-weight:600;letter-spacing:-.02em;font-size:clamp(32px,3.8vw,56px);line-height:.94;color:var(--cream);opacity:0;transform:translateY(20px);transition:opacity 1.2s var(--ease) .72s,transform 1.2s var(--ease) .72s;}
.hero .big .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;letter-spacing:0;color:var(--blue-soft);}
.hero.ready .eyebrow{opacity:1;transform:none;}.hero.ready .big{opacity:1;transform:none;}

.band{padding:118px 0;}
.band--ink{background:var(--ink);}.band--navy{background:var(--navy);}
.head{max-width:840px;margin:0 0 60px;}

/* package cards — image top + roman numeral detail */
.pcards{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;align-items:start;}
.pcard{border:1px solid var(--line);border-radius:10px;overflow:hidden;background:rgba(168,207,224,.02);display:flex;flex-direction:column;transition:border-color .5s var(--ease),transform .5s var(--ease);}
.pcard:hover{border-color:var(--line-2);transform:translateY(-5px);}
/* all three cards uniform — no raised or tinted middle */
.pcard__img{position:relative;aspect-ratio:16/10;overflow:hidden;background:var(--panel);}
.pcard__img img{width:100%;height:100%;object-fit:cover;transition:transform 1.2s var(--ease);}
.pcard:hover .pcard__img img{transform:scale(1.05);}
.pop__tag{position:absolute;top:16px;left:50%;transform:translateX(-50%);background:rgba(10,22,40,.88);color:var(--blue-soft);border:1px solid rgba(168,207,224,.4);font-size:9.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;padding:9px 16px;border-radius:999px;-webkit-backdrop-filter:blur(6px);backdrop-filter:blur(6px);white-space:nowrap;}
.pcard__body{padding:36px 32px 34px;display:flex;flex-direction:column;flex:1;}
.pcard .num{font-family:var(--serif);font-weight:500;font-size:60px;line-height:.8;color:var(--cream);}
.pcard .plabel{margin-top:20px;font-size:11px;font-weight:600;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);}
.pcard .plabel::before{content:"— ";}
.pcard .pname{margin:12px 0 0;font-family:var(--sans);font-weight:600;font-size:28px;line-height:1.06;letter-spacing:-.01em;color:var(--cream);}
.pcard .pname em{display:block;font-family:var(--serif);font-style:italic;font-weight:400;font-size:1.06em;color:var(--blue-soft);}
.pcard .ptag{margin:22px 0 0;border-left:2px solid var(--line-2);padding-left:16px;font-family:var(--serif);font-style:italic;font-size:18px;line-height:1.42;color:var(--blue-soft);}
.pcard .pdesc{margin:22px 0 0;color:rgba(244,246,248,.66);font-size:15px;line-height:1.72;}
.pcard .pmeta{margin:26px 0 0;display:flex;flex-direction:column;}
.pcard .mr{padding:16px 0;border-top:1px solid var(--line);}
.pcard .mk{display:block;font-size:10px;font-weight:600;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.pcard .mk::before{content:"— ";}
.pcard .mv{display:block;margin-top:8px;font-size:15px;font-weight:500;line-height:1.5;color:var(--cream);}
.pcard .pbtn{margin-top:30px;display:flex;align-items:center;justify-content:center;gap:11px;border:0;border-radius:4px;padding:18px 22px;font-size:11.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--ink);background:var(--blue-soft);box-shadow:0 8px 22px rgba(168,207,224,.14);transition:background .4s var(--ease),transform .4s var(--ease),box-shadow .4s var(--ease);}
.pcard .pbtn .arw{transition:transform .5s var(--ease);}
.pcard:hover .pbtn{background:var(--blue);transform:translateY(-2px);box-shadow:0 12px 28px rgba(168,207,224,.22);}
.pcard:hover .pbtn .arw{transform:translateX(6px);}

/* eleven zones split */
.zones__grid{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(40px,6vw,78px);align-items:center;}
.zones__img{border-radius:12px;overflow:hidden;box-shadow:0 40px 90px rgba(0,0,0,.42);}
.zones__img img{width:100%;display:block;}
.zones__h{font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(30px,3.6vw,48px);line-height:1.06;color:var(--cream);margin:18px 0 22px;}
.zones__p{color:rgba(244,246,248,.66);font-size:16.5px;line-height:1.8;margin:0 0 16px;max-width:54ch;}
@media(max-width:980px){.zones__grid{grid-template-columns:1fr;gap:36px;}.zones__img{order:-1;}}

/* every-week strip */
.features{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--line);border:1px solid var(--line);}
.feature{background:var(--navy);padding:38px 32px;}
.feature h4{margin:0 0 12px;font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--blue-soft);}
.feature p{margin:0;color:rgba(244,246,248,.7);font-size:14.5px;line-height:1.7;}

.cta{background:var(--navy);text-align:center;padding:120px 0;border-top:1px solid var(--line);}
.cta .eyebrow{justify-content:center;display:flex;width:max-content;margin:0 auto 26px;}
.cta h2{margin:0 auto 38px;font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(30px,4vw,54px);line-height:1.04;color:var(--cream);max-width:20ch;}
.cta h2 .s{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}
.btn{display:inline-flex;align-items:center;gap:14px;cursor:pointer;background:transparent;border:1px solid var(--cta-line);border-radius:var(--radius);color:var(--cream);font-family:inherit;font-size:11px;font-weight:600;letter-spacing:.22em;text-transform:uppercase;padding:17px 40px;position:relative;overflow:hidden;transition:border-color .6s var(--ease);}
.btn::before{content:"";position:absolute;inset:0;background:rgba(168,207,224,.12);transform:scaleX(0);transform-origin:left;transition:transform .6s var(--ease);}
.btn span{position:relative;z-index:1;}.btn .arw{position:relative;z-index:1;transition:transform .6s var(--ease);}
.btn:hover{border-color:rgba(168,207,224,.8);}.btn:hover::before{transform:scaleX(1);}.btn:hover .arw{transform:translateX(6px);}

.sf{background:var(--ink);border-top:1px solid var(--line);}
.sf .shell{padding:60px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:62px;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
.sf__nav a{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,246,248,.72);}.sf__nav a:hover{color:var(--blue-soft);}
.sf__mid{text-align:center;border-top:1px solid var(--line);padding:58px 0 0;}
.sf__mid .big{font-family:var(--serif);font-style:italic;font-size:clamp(30px,5.6vw,72px);color:var(--cream);}
.sf__trust{margin:34px 0 56px;text-align:center;font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,.5);}
.sf__trust b{font-weight:600;color:var(--blue-soft);}
.sf__base{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px;}
.sf__base .cr{font-size:11px;color:rgba(244,246,248,.32);}
.sf__base a{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(168,207,224,.72);}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s var(--ease),transform .9s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media (prefers-reduced-motion:reduce){.reveal,.hero__photo,.hero .eyebrow,.hero .big{opacity:1!important;transform:none!important;transition:none!important;}*{scroll-behavior:auto!important;}}

@media(max-width:980px){.pcards{grid-template-columns:1fr;max-width:460px;}.features{grid-template-columns:1fr 1fr;}}
@media(max-width:900px){
  .shell{padding:0 24px;}.burger{display:flex;}
  .menu{position:fixed;top:0;right:0;bottom:0;width:min(80vw,360px);background:rgba(10,22,40,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px 36px;transform:translateX(100%);transition:transform .6s var(--ease);}
  body.nav-open .menu{transform:none;}
  .menu a{font-size:18px;letter-spacing:.06em;text-transform:none;padding:14px 0;color:var(--cream);}.menu a::after{display:none;}
  .hero{min-height:68vh;padding-bottom:56px;}
  .band{padding:76px 0;}
  .features{grid-template-columns:1fr;}
