---
import Base from '../layouts/Base.astro';
const S = 'https://heliskitravel.com';
const productSchema = {
  "@type":"Product",
  "name":"Private Heliskiing — Iceland (Exclusive Helicopter Charter)",
  "description":"Your own helicopter, schedule and Troll Peninsula playground. Up to four skiers plus an IFMGA guide, based at Sigló Hótel, North Iceland.",
  "brand":{"@type":"Organization","name":"Viking Heliskiing"},
  "category":"Private heliskiing charter",
  "image": S + "/images/private-hero.jpg",
  "offers":[
    {"@type":"Offer","name":"3-Day Private Charter","price":"48990","priceCurrency":"EUR","availability":"https://schema.org/InStock","url": S + "/private-heliskiing"},
    {"@type":"Offer","name":"4-Day Private Charter","price":"64990","priceCurrency":"EUR","availability":"https://schema.org/InStock","url": S + "/private-heliskiing"},
    {"@type":"Offer","name":"5-Day Private Charter","price":"82990","priceCurrency":"EUR","availability":"https://schema.org/InStock","url": S + "/private-heliskiing"}
  ]
};
const faqLd = {
  "@type":"FAQPage",
  "mainEntity":[
    {"@type":"Question","name":"How much does private heliskiing in Iceland cost?","acceptedAnswer":{"@type":"Answer","text":"A private, exclusive-helicopter charter with Viking Heliskiing costs €48,990 for 3 days, €64,990 for 4 days and €82,990 for 5 days — per group, with full board at the 4-star Sigló Hótel. Booking through Heliski Travel costs exactly the same as booking direct."}},
    {"@type":"Question","name":"What makes private heliskiing different from a shared week?","acceptedAnswer":{"@type":"Answer","text":"You get your own dedicated helicopter and your own IFMGA guide, with your group alone — your terrain, your schedule and your pace. There is no sharing and no rotation between groups, so you fly and ski entirely on your own timing."}},
    {"@type":"Question","name":"How many people can join a private charter?","acceptedAnswer":{"@type":"Answer","text":"Up to four skiers or snowboarders plus one IFMGA guide fly in the private helicopter. The price is per group, so it is most cost-effective for a full group of four."}},
    {"@type":"Question","name":"What is included in the private heliskiing package?","acceptedAnswer":{"@type":"Answer","text":"The exclusive helicopter and IFMGA guide, nights at the 4-star ocean-front Sigló Hótel, full board (breakfast, lunch and dinner), full ski or snowboard equipment, a BCA avalanche safety kit, transfers, and unlimited hot tubs and sauna. International flights and travel insurance are not included."}},
    {"@type":"Question","name":"When is the private heliskiing season?","acceptedAnswer":{"@type":"Answer","text":"The Troll Peninsula season runs from 10 March to 6 June — from the Northern Lights in early season to the midnight sun in late spring."}},
    {"@type":"Question","name":"Is private heliskiing worth it over the shared Classic week?","acceptedAnswer":{"@type":"Answer","text":"If privacy, flexibility and skiing entirely on your own schedule matter most, a private charter delivers that — you are never tied to another group's timing or rotation. If value is the priority, the shared Classic week gives you the same terrain and guiding at a far lower price."}},
    {"@type":"Question","name":"Does booking through Heliski Travel cost extra?","acceptedAnswer":{"@type":"Answer","text":"No. Heliski Travel is the authorised booking agent for Viking Heliskiing, so booking through us costs exactly the same as booking direct — no markup and no booking fee — plus impartial advice on the right format for your group."}}
  ]
};
const body = `

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__photo" id="heroPhoto"></div>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" href="#" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell"><h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Private Heliskiing — Iceland</h1></div>
</section>

<!-- INTRO + PRICING -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Private · Exclusive</p>
      <h2 class="sectit">Private Heliskiing<span class="s">in North Iceland.</span></h2>
      <p class="intro">One dedicated helicopter, one professional guide, your group alone. Your terrain, your schedule, your pace. Everything included — hotel, food, equipment, transfers. The ultimate Arctic experience on the Troll Peninsula.</p>
    </div>
    <div class="tiers">
      <div class="tier reveal"><p class="dur">Three days</p><div class="price">€48,990</div><p class="per">per group</p><button class="moreinfo" type="button" data-pkgmodal-open data-week="3"><span>More information</span> <span class="arw">→</span></button>
        <dl><div><dt>Helicopter</dt><dd>Private · exclusive</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Breakfast, lunch &amp; dinner</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + 1 guide</dd></div></dl>
        <a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
      <div class="tier feat reveal"><span class="badge">Most popular</span><p class="dur">Four days</p><div class="price">€64,990</div><p class="per">per group</p><button class="moreinfo" type="button" data-pkgmodal-open data-week="4"><span>More information</span> <span class="arw">→</span></button>
        <dl><div><dt>Helicopter</dt><dd>Private · exclusive</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Breakfast, lunch &amp; dinner</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + 1 guide</dd></div></dl>
        <a class="btn btn--solid" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
      <div class="tier reveal"><p class="dur">Five days</p><div class="price">€82,990</div><p class="per">per group</p><button class="moreinfo" type="button" data-pkgmodal-open data-week="5"><span>More information</span> <span class="arw">→</span></button>
        <dl><div><dt>Helicopter</dt><dd>Private · exclusive</dd></div><div><dt>Accommodation</dt><dd>Sigló Hotel</dd></div><div><dt>Meals</dt><dd>Breakfast, lunch &amp; dinner</dd></div><div><dt>Season</dt><dd>Mar 10 – Jun 6</dd></div><div><dt>Group</dt><dd>4 skiers + 1 guide</dd></div></dl>
        <a class="btn" href="/contact"><span>Request availability</span> <span class="arw">→</span></a></div>
    </div>
  </div>
</section>

<!-- THE FULL WEEK MODAL -->
<div class="pkgm" id="pkgm" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Private Heliskiing — full week details">
  <div class="pkgm__panel">
    <div class="pkgm__head">
      <div><p class="eyebrow">Private Heliskiing · Iceland</p><h2>The full week,<span class="s"> in detail.</span></h2></div>
      <button class="pkgm__x" type="button" data-pkgmodal-close aria-label="Close">&times;</button>
    </div>
    <div class="pkgm__body">
      <div class="pkgm__rail">
        <p class="eyebrow">Choose your week</p>
        <div class="pkgm__weeks">
          <button class="wk" type="button" data-days="3" data-vert=""><span class="wk__d">3-Day week</span><span class="wk__v">Private · exclusive heli</span><span class="wk__p">€48,990 · per group</span></button>
          <button class="wk active" type="button" data-days="4" data-vert=""><span class="wk__d">4-Day week</span><span class="wk__v">Private · exclusive heli</span><span class="wk__p">€64,990 · per group</span><span class="wk__pop">★ Most popular</span></button>
          <button class="wk" type="button" data-days="5" data-vert=""><span class="wk__d">5-Day week</span><span class="wk__v">Private · exclusive heli</span><span class="wk__p">€82,990 · per group</span></button>
        </div>
        <a class="btn btn--solid pkgm__cta" href="/contact"><span>Request availability</span> <span class="arw">→</span></a>
      </div>
      <div class="pkgm__main">
        <h3>What's included</h3>
        <ul class="pkgm__incl">
          <li><b data-count>4</b> × nights at Sigló Hotel (4-star, ocean-front)</li>
          <li><b data-count>4</b> × 3-course dinners at Sigló Restaurant</li>
          <li><b data-count>4</b> × daily breakfast buffet at Sigló Hotel</li>
          <li><b data-count>4</b> × lunches at the Club House K2 Ski</li>
          <li>Private, exclusive helicopter — your group only</li>
          <li>Dedicated IFMGA mountain guide</li>
          <li>Full ski equipment — skis, boots, poles</li>
          <li>BCA avalanche safety kit — transceiver, shovel, probe, airbag</li>
          <li>Outdoor hot tub &amp; sauna — unlimited access</li>
          <li>Daily yoga &amp; morning stretches</li>
        </ul>

        <h3 class="pkgm__h2">The mountain, entirely yours.</h3>
        <p>The exclusive week. A dedicated helicopter and private guide, entirely on your terms — choose your lines, set your pace, and fly when you want. No sharing, no fixed rotation.</p>
        <p>Whether it's a family, a group of friends, or a corporate trip, the whole operation flexes around you across the Troll Peninsula — couloirs, alpine bowls and peak-to-ocean descents, guided by IFMGA-certified guides who have skied this peninsula their whole lives.</p>
        <p>Ski beneath the midnight sun in spring, or chase the Northern Lights in early season. Powder, spring corn, untouched lines — and at night, a hot tub, a sauna, and a 4-star ocean-front room waiting in the fishing village of Siglufjörður.</p>

        <h3 class="pkgm__h2">A typical day</h3>
        <p>With your own helicopter and guide, the day bends to you — fly when you want, ski the lines you choose, and take as many runs as the conditions and your legs allow. Here is how a day tends to unfold.</p>

        <p class="pkgm__lbl">Typical heliskiing day<span class="pkgm__ast">*</span></p>
        <ol class="pkgm__time">
          <li><span class="t">07:00–09:00</span><span class="d">Enjoy a hearty breakfast at the hotel to fuel up for the day.</span></li>
          <li><span class="t">08:30–09:00</span><span class="d">Pick-up for a quick 3-minute drive to the Clubhouse, where your skis or snowboard await you for a day of fun and excitement. Our guides will review the day's plan, ensuring you are well-prepared and informed.</span></li>
          <li><span class="t">09:45–10:00</span><span class="d">Helicopters are ready to take you on an exhilarating day of skiing.</span></li>
          <li><span class="t">12:30–13:30</span><span class="d">Get ready for lunch with a view! You will get the opportunity to enjoy your meal with stunning views and great company.</span></li>
          <li><span class="t">15:00–16:00</span><span class="d">Return to the Clubhouse, where après ski awaits. Delicious, freshly prepared food and a variety of drinks to refresh your body and mind. Here you have the chance to talk about the day and exchange stories, photos, and videos with upbeat music in the background. You can also head back to the hotel for a dip in the hot tub, explore the town, try kayaking, visit the local brewery, or join some of the other activities we offer before it's time for dinner.</span></li>
          <li><span class="t">20:00</span><span class="d">A three-course dinner will be served at the hotel. Throughout your stay, you will get a variety of dishes locally sourced from Icelandic nature, such as cod, salmon, lamb, and more. After dinner is the perfect time for drinks around the fireplace.</span></li>
        </ol>
        <p class="pkgm__foot">*This is a sample itinerary as times and schedule may vary depending on weather conditions</p>
      </div>
    </div>
  </div>
</div>

<!-- MORE THAN -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Also in every week</p>
      <h2 class="sectit">More than <span class="s">the flights.</span></h2>
      <p class="intro">Every private week includes the full off-mountain experience — Sigló at sunset, field lunch on the peak, K2 gear, morning stretches, and communal dinners.</p>
    </div>
    <div class="features reveal">
      <div class="feature"><h3>Field lunch</h3><p>Fresh-cut sandwiches and dessert wine, on the mountain between runs.</p></div>
      <div class="feature"><h3>Yoga &amp; stretches</h3><p>Optional morning stretches every day — recommended after a helicopter day.</p></div>
      <div class="feature"><h3>Private guide</h3><p>One dedicated group. Your helicopter flies only for you.</p></div>
      <div class="feature"><h3>Equipment</h3><p>K2 freeride skis with Marker bindings, K2 poles and K2 snowboards.</p></div>
      <div class="feature"><h3>Après-ski</h3><p>Hot tubs, communal dinners, and the bar at Sigló — all yours.</p></div>
      <div class="feature"><h3>Season</h3><p>March 10 to June 6 — ten weeks of stable Arctic light.</p></div>
    </div>
    <p class="note reveal"><b style="color:var(--blue-soft);font-weight:600;">Not included:</b> International &amp; domestic flights · Travel &amp; cancellation insurance · Beverages · Credit card fees · Transfer &amp; sightseeing flights.</p>
  </div>
</section>

<!-- GALLERY -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Gallery</p>
      <h2 class="sectit">A week <span class="s">in pictures.</span></h2>
    </div>
    <div class="gal reveal">
      <a href="/images/gallery/heliskiers-descent-fjord-helicopter-iceland.webp" target="_blank" rel="noopener"><img src="/images/gallery/heliskiers-descent-fjord-helicopter-iceland.webp" alt="Private heliskiing descent toward the Arctic fjord, Troll Peninsula Iceland" loading="lazy" decoding="async" width="1000" height="750"/></a>
      <a href="/images/gallery/heliski-guides-ridge-sunset-iceland.webp" target="_blank" rel="noopener"><img src="/images/gallery/heliski-guides-ridge-sunset-iceland.webp" alt="Private group and guide on a summit ridge at sunset, North Iceland" loading="lazy" decoding="async" width="1000" height="750"/></a>
      <a href="/images/gallery/skier-summit-blue-sky-troll-peninsula.webp" target="_blank" rel="noopener"><img src="/images/gallery/skier-summit-blue-sky-troll-peninsula.webp" alt="Skier on a private summit under blue Arctic sky, Troll Peninsula" loading="lazy" decoding="async" width="1000" height="750"/></a>
      <a href="/images/gallery/heliski-helicopter-guests-sunset-iceland.webp" target="_blank" rel="noopener"><img src="/images/gallery/heliski-helicopter-guests-sunset-iceland.webp" alt="Private helicopter and guests at sunset in the North Iceland mountains" loading="lazy" decoding="async" width="1000" height="750"/></a>
      <a href="/images/gallery/golden-fjord-reflection-siglufjordur-iceland.webp" target="_blank" rel="noopener"><img src="/images/gallery/golden-fjord-reflection-siglufjordur-iceland.webp" alt="Golden fjord reflection near Siglufjörður at sunset, Iceland" loading="lazy" decoding="async" width="1000" height="750"/></a>
      <a href="/images/gallery/summit-bonfire-apres-heliski-iceland.webp" target="_blank" rel="noopener"><img src="/images/gallery/summit-bonfire-apres-heliski-iceland.webp" alt="Private summit bonfire and charcuterie at sunset with the helicopter, Iceland" loading="lazy" decoding="async" width="1000" height="750"/></a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="band band--navy" aria-labelledby="faq-h">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">Questions</p>
      <h2 class="sectit" id="faq-h">Private heliskiing,<span class="s">answered.</span></h2>
    </div>
    <div class="faqx reveal" style="max-width:860px;border-top:1px solid var(--line);">
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">How much does private heliskiing in Iceland cost?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">A private, exclusive-helicopter charter runs <b style="color:var(--blue-soft);font-weight:600;">€48,990</b> for 3 days, €64,990 for 4 days and €82,990 for 5 days — per group, full board at the 4-star Sigló Hótel. Booking through us costs the same as booking direct.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">What makes it private?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">Your own dedicated helicopter and IFMGA guide, with your group alone — your terrain, your schedule, your pace. No sharing and no rotation between groups.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">How many people can join?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">Up to four skiers or snowboarders plus one IFMGA guide fly in the private helicopter. The price is per group, so it is most cost-effective for a full four.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">What is included?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">The exclusive helicopter and guide, nights at the 4-star Sigló Hótel, full board, equipment, a BCA avalanche safety kit, transfers, and unlimited hot tubs and sauna. Flights and travel insurance are not included.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">When is the season?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;"><b style="color:var(--blue-soft);font-weight:600;">10 March to 6 June</b> — from the Northern Lights in early season to the midnight sun in late spring.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">Is private worth it over the shared Classic week?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">If privacy, flexibility and skiing on your own schedule matter most, yes — you are never tied to another group's timing. If value is the priority, the shared <a href="/classic-heliskiing" style="color:var(--blue-soft);text-decoration:underline;text-underline-offset:3px;">Classic week</a> gives the same terrain at a far lower price.</p></div>
      <div style="border-bottom:1px solid var(--line);padding:26px 0;"><h3 style="margin:0 0 10px;font-family:var(--sans);font-weight:600;font-size:19px;color:var(--cream);letter-spacing:-.01em;">Does booking through Heliski Travel cost extra?</h3><p style="margin:0;color:rgba(244,246,248,.72);font-size:15.5px;line-height:1.8;">No — we are the authorised agent, so it costs exactly the same as booking direct, plus impartial advice on the right format. <a href="/contact" style="color:var(--blue-soft);text-decoration:underline;text-underline-offset:3px;">Ask us anything</a>.</p></div>
    </div>
  </div>
</section>

<!-- FOOTER -->
`;
---
<Base heroImage="private-hero" title="Private Heliskiing in Iceland | Heliski Travel" description="Private heliskiing in Iceland: your own helicopter, schedule and Troll Peninsula playground. Up to 4 skiers + guide, Sigló Hotel, IFMGA. From €48,990." active="packages" schema={[productSchema, faqLd]}>
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/private-hero.webp");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--sans);font-weight:600;letter-spacing:-.015em;font-size:clamp(34px,5vw,60px);line-height:1.02;color:var(--cream);margin:22px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.04em;line-height:1;letter-spacing:0;}
.intro{margin:26px 0 0;color:rgba(244,246,248,0.68);font-size:17px;line-height:1.82;max-width:64ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,0.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,0.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
