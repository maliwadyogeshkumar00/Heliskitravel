---
import Base from '../layouts/Base.astro';
const S = 'https://heliskitravel.com';
const hotelSchema = {
  "@type":"Hotel",
  "name":"Sigló Hótel",
  "description":"4-star design hotel on the harbour in Siglufjörður, North Iceland — the basecamp for Viking Heliskiing, a five-minute walk from the helipad.",
  "image": S + "/images/siglo-hero.jpg",
  "starRating":{"@type":"Rating","ratingValue":"4"},
  "address":{"@type":"PostalAddress","addressLocality":"Siglufjörður","addressCountry":"IS"},
  "geo":{"@type":"GeoCoordinates","latitude":66.1516,"longitude":-18.9075},
  "amenityFeature":[
    {"@type":"LocationFeatureSpecification","name":"Restaurant","value":true},
    {"@type":"LocationFeatureSpecification","name":"Geothermal hot tubs","value":true},
    {"@type":"LocationFeatureSpecification","name":"Harbour-front location","value":true}
  ]
};
const body = `

<!-- HERO -->
<section class="hero" id="hero">
  <div class="hero__photo" id="heroPhoto"></div>
  <div class="grade"></div>
  <a class="scrolldn" aria-label="Scroll down" href="#" onclick="window.scrollTo({top:Math.round(innerHeight*0.9),behavior:'smooth'});return false;"><span></span></a>
  <div class="shell"><h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;">Sigló Hotel — Heliskiing Basecamp</h1></div>
</section>

<!-- INTRO -->
<section class="band band--ink">
  <div class="shell intro2">
    <div class="reveal">
      <p class="eyebrow">The Basecamp</p>
      <p class="statement">Sigló Hotel sits directly on the harbour of Siglufjörður — where dramatic fjord mountains meet the Greenland Sea.</p>
    </div>
    <div class="reveal">
      <p class="body">One of the most beautifully positioned hotels in Iceland — intimate, design-led, and quietly extraordinary. Nordic warmth, honest local food, and harbour views from every room. The views from bed are unforgettable.</p>
      <div class="facts">
        <div class="f"><span class="fk">Location</span><span class="fv">Harbourfront · Siglufjörður</span></div>
        <div class="f"><span class="fk">To the helipad</span><span class="fv">5-minute walk</span></div>
        <div class="f"><span class="fk">Dining</span><span class="fv">Sunna · nightly three-course</span></div>
        <div class="f"><span class="fk">Setting</span><span class="fv">40 km north of the Arctic Circle</span></div>
      </div>
    </div>
  </div>
</section>

<!-- THE SIGLÓ EXPERIENCE — feature blocks -->
<section class="band band--navy">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">The Sigló Experience</p>
      <h2 class="sectit">Everything you need,<span class="s">in one remarkable place.</span></h2>
    </div>

    <div class="feat reveal">
      <div class="feat__img"><img src="/brand/siglo-hotel-2.webp" srcset="/brand/siglo-hotel-2.webp 640w, /brand/siglo-hotel-2.webp 1080w, /brand/siglo-hotel-2.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel on the harbour" loading="lazy" decoding="async" width="800" height="600"/></div>
      <div class="feat__txt"><span class="ix">01</span><p class="eyebrow">The Hotel</p><h3>Sigló Hotel.</h3><p>One of Iceland's most celebrated boutique hotels, sitting directly on the harbour of Siglufjörður. Nordic design, Icelandic warmth, ocean views from every room, and access to the legendary outdoor hot tubs overlooking the fjord.</p></div>
    </div>

    <div class="feat reveal">
      <div class="feat__img"><img src="/brand/siglo-fine-dining.webp" srcset="/brand/siglo-fine-dining.webp 640w, /brand/siglo-fine-dining.webp 1080w, /brand/siglo-fine-dining.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sunna Restaurant fine dining" loading="lazy" decoding="async" width="800" height="600"/></div>
      <div class="feat__txt"><span class="ix">02</span><p class="eyebrow">Fine Dining</p><h3>Sunna Restaurant.</h3><p>Sigló's harbourside restaurant serves a nightly three-course dinner inspired by North Icelandic ingredients — fresh-caught fish, local lamb, and seasonal produce. Intimate, candlelit, and utterly unhurried.</p></div>
    </div>

    <div class="feat reveal">
      <div class="feat__img"><img src="/brand/siglufjordur-town.webp" srcset="/brand/siglufjordur-town.webp 640w, /brand/siglufjordur-town.webp 1080w, /brand/siglufjordur-town.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Siglufjörður fishing town" loading="lazy" decoding="async" width="800" height="600"/></div>
      <div class="feat__txt"><span class="ix">03</span><p class="eyebrow">The Town</p><h3>Siglufjörður.</h3><p>A remote fishing town 40 kilometres north of the Arctic Circle, framed by towering mountains on three sides and the Greenland Sea beyond. Colourful, quiet, and genuinely unspoiled — one of Iceland's best-kept secrets.</p></div>
    </div>
  </div>
</section>

<!-- GALLERY -->
<section class="band band--ink">
  <div class="shell">
    <div class="head reveal">
      <p class="eyebrow">In Every Frame</p>
      <h2 class="sectit">The Sigló experience,<span class="s">in every frame.</span></h2>
      <p class="intro">Nordic design. Icelandic warmth. An Arctic harbour unlike anywhere else.</p>
    </div>
    <div class="gal reveal">
      <a class="tall" href="/wp/2026/05/Siglo-Hotel-Gallery.webp" target="_blank" rel="noopener"><img src="/brand/siglo-hotel-g1.webp" srcset="/brand/siglo-hotel-g1.webp 640w, /brand/siglo-hotel-g1.webp 1080w, /brand/siglo-hotel-g1.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel" loading="lazy" decoding="async" width="800" height="600"/></a>
      <a href="/wp/2026/06/siglo-hotel-sunset.jpg" target="_blank" rel="noopener"><img src="/brand/siglo-sunset.webp" srcset="/brand/siglo-sunset.webp 640w, /brand/siglo-sunset.webp 1080w, /brand/siglo-sunset.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel at sunset" loading="lazy" decoding="async" width="800" height="600"/></a>
      <a href="/wp/2026/06/siglo-hotel-suite-siglufjordur.jpg" target="_blank" rel="noopener"><img src="/brand/siglo-suite.webp" srcset="/brand/siglo-suite.webp 640w, /brand/siglo-suite.webp 1080w, /brand/siglo-suite.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel suite" loading="lazy" decoding="async" width="800" height="600"/></a>
      <a class="tall" href="/wp/2026/05/Siglo-Hotel-Gallery-5.webp" target="_blank" rel="noopener"><img src="/brand/siglo-hotel-g5.webp" srcset="/brand/siglo-hotel-g5.webp 640w, /brand/siglo-hotel-g5.webp 1080w, /brand/siglo-hotel-g5.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel harbour" loading="lazy" decoding="async" width="800" height="600"/></a>
      <a href="/wp/2026/06/siglo-hotel-lounge-fireplace.jpg" target="_blank" rel="noopener"><img src="/brand/siglo-lounge.webp" srcset="/brand/siglo-lounge.webp 640w, /brand/siglo-lounge.webp 1080w, /brand/siglo-lounge.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel lounge fireplace" loading="lazy" decoding="async" width="800" height="600"/></a>
      <a href="/wp/2026/06/siglo-hotel-superior-room.jpg" target="_blank" rel="noopener"><img src="/brand/siglo-superior-room.webp" srcset="/brand/siglo-superior-room.webp 640w, /brand/siglo-superior-room.webp 1080w, /brand/siglo-superior-room.webp 1200w" sizes="(max-width:767px) 100vw, 620px" alt="Sigló Hotel superior room" loading="lazy" decoding="async" width="800" height="600"/></a>
    </div>
  </div>
</section>

<!-- HOT TUBS full-bleed -->
<section class="fullband">
  <div class="fullband__photo" style="background-image:url('/brand/siglo-sunset.webp')"></div>
  <div class="fullband__grade"></div>
  <div class="shell">
    <p class="eyebrow">A word about the hot tubs</p>
    <h2>After a day on the mountain,<span class="s">the hot tubs are remarkable.</span></h2>
  </div>
</section>

<!-- FOOTER -->
`;
---
<Base heroImage="siglo-hero" title="Sigló Hotel: Iceland Heliskiing Basecamp | Heliski Travel" description="Stay at Sigló Hotel in Siglufjörður, Iceland's northernmost heliski basecamp. Design-led harbour rooms, Nordic cuisine, 5-min walk to the helipad." active="siglo" schema={hotelSchema}>
  <Fragment set:html={body} />
</Base>

<style is:global>
:root{--ink:#0A1628;--navy:#172D42;--panel:#15293c;--cream:#F4F6F8;--blue:#A8CFE0;--blue-soft:#C3DCEE;--muted:rgba(195,220,238,.55);--line:rgba(138,180,204,.16);--line-2:rgba(138,180,204,.30);--cta-line:rgba(168,207,224,.45);--radius:3px;--ease:cubic-bezier(.16,1,.3,1);--maxw:1240px;--sans:"Mulish",-apple-system,"Segoe UI",Roboto,sans-serif;--serif:"Cormorant Garamond",Georgia,serif;--hero:url("/images/siglo-hero.webp");}
*{box-sizing:border-box;}html{scroll-behavior:smooth;}
body{margin:0;background:var(--ink);color:var(--cream);font-family:var(--sans);font-size:16px;line-height:1.6;-webkit-font-smoothing:antialiased;}
body.nav-open{overflow:hidden;}
img{max-width:100%;display:block;}a{color:inherit;text-decoration:none;}
:focus-visible{outline:2px solid var(--blue);outline-offset:3px;}
.shell{max-width:var(--maxw);margin:0 auto;padding:0 48px;width:100%;}
.eyebrow{display:inline-flex;align-items:center;gap:14px;font-size:11.5px;font-weight:600;letter-spacing:.28em;text-transform:uppercase;color:var(--blue-soft);margin:0;}
.eyebrow::before{content:"";width:30px;height:1px;background:var(--blue);opacity:.85;}
.progress{position:fixed;top:0;left:0;height:2px;width:0;z-index:80;background:linear-gradient(90deg,var(--blue),rgba(168,207,224,.35));transition:width .12s linear;}
.sectit{font-family:var(--sans);font-weight:600;letter-spacing:-.015em;font-size:clamp(36px,5.4vw,64px);line-height:1.02;color:var(--cream);margin:22px 0 0;}
.sectit .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);font-size:1.04em;line-height:1;letter-spacing:0;}
.intro{margin:28px 0 0;color:rgba(244,246,248,0.68);font-size:17px;line-height:1.8;max-width:60ch;}

header{position:fixed;top:0;left:0;right:0;z-index:70;transition:background .7s var(--ease),border-color .7s var(--ease);border-bottom:1px solid transparent;}
header::before{content:"";position:absolute;left:0;right:0;top:0;height:200%;pointer-events:none;z-index:0;background:linear-gradient(180deg,rgba(10,22,40,.66),rgba(10,22,40,.38) 42%,rgba(10,22,40,.12) 72%,rgba(10,22,40,0));opacity:1;transition:opacity .7s var(--ease);}
header.scrolled{background:rgba(10,22,40,.74);backdrop-filter:saturate(140%) blur(14px);-webkit-backdrop-filter:saturate(140%) blur(14px);border-bottom-color:rgba(138,180,204,.12);}
header.scrolled::before{opacity:0;}
.nav{display:flex;align-items:center;justify-content:space-between;height:96px;position:relative;z-index:2;}
.nav .logo img{height:64px;width:auto;filter:drop-shadow(0 2px 10px rgba(10,22,40,.5));transition:height .7s var(--ease),filter .7s var(--ease);}
header.scrolled .nav{height:80px;}header.scrolled .logo img{height:52px;}
.menu{display:flex;align-items:center;gap:40px;}
.menu a{font-size:12.5px;letter-spacing:.14em;text-transform:uppercase;color:rgba(244,246,248,0.85);padding:6px 0;position:relative;transition:color .5s var(--ease);}
.menu a::after{content:"";position:absolute;left:0;right:100%;bottom:-4px;height:1px;background:var(--blue);transition:right .5s var(--ease);}
.menu a:hover::after,.menu a.active::after{right:0;}.menu a:hover,.menu a.active{color:var(--cream);}
.menu .caret{font-size:9px;opacity:.6;margin-left:5px;}
.menu .hassub{position:relative;display:inline-flex;align-items:center;}
.submenu{position:absolute;top:100%;left:-14px;margin-top:6px;min-width:240px;display:flex;flex-direction:column;gap:2px;padding:10px;background:rgba(10,22,40,.97);backdrop-filter:blur(14px);-webkit-backdrop-filter:blur(14px);border:1px solid var(--line);border-radius:8px;box-shadow:0 22px 54px rgba(0,0,0,.46);opacity:0;visibility:hidden;transform:translateY(8px);transition:opacity .35s var(--ease),transform .35s var(--ease),visibility .35s;z-index:9;}
.submenu::before{content:"";position:absolute;top:-10px;left:0;right:0;height:10px;}
.menu .hassub:hover .submenu,.menu .hassub:focus-within .submenu{opacity:1;visibility:visible;transform:none;}
.submenu a{padding:11px 14px;border-radius:5px;font-size:11.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(244,246,248,0.8);}
.submenu a::after{display:none;}
.submenu a:hover{background:rgba(168,207,224,.1);color:var(--cream);}
@media(max-width:900px){.menu .hassub{flex-direction:column;align-items:flex-start;width:100%;}.submenu{position:static;opacity:1;visibility:visible;transform:none;background:none;border:0;box-shadow:none;padding:4px 0 2px 16px;margin:0;min-width:0;}.submenu::before{display:none;}.submenu a{padding:10px 0;font-size:15px;text-transform:none;letter-spacing:.04em;color:rgba(244,246,248,0.7);}}
.burger{display:none;width:44px;height:44px;border:0;background:transparent;cursor:pointer;flex-direction:column;justify-content:center;align-items:flex-end;gap:6px;z-index:71;}
.burger span{display:block;height:1.5px;background:var(--cream);transition:transform .5s var(--ease),opacity .3s,width .5s;}
.burger span:nth-child(1){width:26px;}.burger span:nth-child(2){width:20px;}.burger span:nth-child(3){width:26px;}
body.nav-open .burger span:nth-child(1){transform:translateY(7.5px) rotate(45deg);width:26px;}
body.nav-open .burger span:nth-child(2){opacity:0;}
body.nav-open .burger span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg);width:26px;}

.hero{position:relative;min-height:100vh;display:flex;align-items:flex-end;padding:0 0 110px;overflow:hidden;background:var(--navy);}
.hero__photo{position:absolute;inset:-3%;z-index:0;background:var(--hero) center 40%/cover no-repeat;opacity:0;transform:scale(1.08);transition:opacity 1.8s var(--ease),transform 2.4s var(--ease);}
.hero.ready .hero__photo{opacity:1;transform:scale(1);}
.hero .grade{position:absolute;inset:0;z-index:1;pointer-events:none;background:linear-gradient(180deg,rgba(10,22,40,0.34) 0%,rgba(10,22,40,0) 22%),linear-gradient(90deg,rgba(10,22,40,0.16) 0%,rgba(10,22,40,0) 52%);}
.hero .shell{position:relative;z-index:3;}
.scrolldn{position:absolute;left:50%;bottom:30px;transform:translateX(-50%);z-index:4;width:24px;height:38px;border:1.5px solid rgba(195,220,238,.5);border-radius:13px;display:flex;justify-content:center;opacity:0;transition:opacity 1s var(--ease) 1.4s;}
.hero.ready .scrolldn{opacity:1;}
.scrolldn span{width:3px;height:8px;border-radius:2px;background:var(--blue);margin-top:7px;animation:scrolldn 1.9s var(--ease) infinite;}
@keyframes scrolldn{0%{transform:translateY(0);opacity:1;}70%{transform:translateY(14px);opacity:0;}100%{opacity:0;}}
.hero .eyebrow{margin-bottom:26px;opacity:0;transform:translateY(12px);transition:opacity 1s var(--ease) .5s,transform 1s var(--ease) .5s;}
.hero .big{margin:0;font-family:var(--sans);font-weight:600;letter-spacing:-.02em;font-size:clamp(32px,3.8vw,56px);line-height:.94;color:var(--cream);opacity:0;transform:translateY(20px);transition:opacity 1.2s var(--ease) .72s,transform 1.2s var(--ease) .72s;}
.hero .big .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;letter-spacing:0;color:var(--blue-soft);}
.hero.ready .eyebrow{opacity:1;transform:none;}.hero.ready .big{opacity:1;transform:none;}

.band{padding:120px 0;}
.band--ink{background:var(--ink);}.band--navy{background:var(--navy);}
.head{max-width:820px;margin:0 0 64px;}

/* editorial intro */
.intro2{display:grid;grid-template-columns:1.15fr 1fr;gap:clamp(40px,6vw,90px);align-items:start;}
.intro2 .statement{font-family:var(--serif);font-style:italic;font-weight:400;font-size:clamp(26px,3.4vw,42px);line-height:1.32;color:var(--cream);margin:18px 0 0;}
.intro2 .body{color:rgba(244,246,248,0.7);font-size:16.5px;line-height:1.85;margin:0;}
.facts{margin-top:34px;border-top:1px solid var(--line);}
.facts .f{display:flex;justify-content:space-between;gap:20px;padding:16px 0;border-bottom:1px solid var(--line);}
.facts .fk{font-size:11px;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);}
.facts .fv{font-size:14.5px;color:var(--cream);text-align:right;}
@media(max-width:980px){.intro2{grid-template-columns:1fr;gap:34px;}}

/* alternating feature blocks with cover photos */
.feat{display:grid;grid-template-columns:1.05fr 1fr;gap:clamp(36px,5vw,72px);align-items:center;padding:60px 0;border-top:1px solid var(--line);}
.feat:first-of-type{border-top:none;}
.feat__img{aspect-ratio:4/3;border-radius:6px;overflow:hidden;background:var(--panel);}
.feat__img img{width:100%;height:100%;object-fit:cover;transition:transform 1.2s var(--ease);}
.feat:hover .feat__img img{transform:scale(1.04);}
.feat:nth-of-type(even) .feat__img{order:2;}
.feat .ix{display:block;font-family:var(--serif);font-style:italic;font-size:24px;color:var(--blue);margin-bottom:18px;}
.feat h3{font-family:var(--serif);font-style:italic;font-weight:400;font-size:clamp(30px,3.6vw,46px);color:var(--cream);margin:14px 0 18px;line-height:1.04;}
.feat p{margin:0;color:rgba(244,246,248,0.7);font-size:16.5px;line-height:1.82;max-width:52ch;}

/* gallery */
.gal{display:grid;grid-template-columns:repeat(3,1fr);grid-auto-rows:300px;gap:18px;margin-top:60px;}
.gal a{position:relative;overflow:hidden;border-radius:4px;background:var(--panel);}
.gal img{width:100%;height:100%;object-fit:cover;transition:transform 1.1s var(--ease);}
.gal a:hover img{transform:scale(1.05);}
.gal a.tall{grid-row:span 2;}

/* full-bleed band */
.fullband{position:relative;min-height:74vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden;}
.fullband__photo{position:absolute;inset:0;z-index:0;background-size:cover;background-position:center;}
.fullband__grade{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,22,40,.5),rgba(10,22,40,.42));}
.fullband .shell{position:relative;z-index:2;}
.fullband .eyebrow{justify-content:center;display:flex;width:max-content;margin:0 auto 26px;}
.fullband h2{margin:0;font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(32px,5vw,64px);line-height:1.04;color:var(--cream);max-width:18ch;margin-left:auto;margin-right:auto;}
.fullband h2 .s{display:block;font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}

.cta{background:var(--navy);text-align:center;padding:120px 0;border-top:1px solid var(--line);}
.cta .eyebrow{justify-content:center;display:flex;width:max-content;margin:0 auto 26px;}
.cta h2{margin:0 auto 38px;font-family:var(--sans);font-weight:600;letter-spacing:-.01em;font-size:clamp(30px,4vw,54px);line-height:1.04;color:var(--cream);max-width:20ch;}
.cta h2 .s{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--blue-soft);}
.btn{display:inline-flex;align-items:center;gap:16px;cursor:pointer;background:transparent;border:1px solid var(--cta-line);border-radius:var(--radius);color:var(--cream);font-family:inherit;font-size:11px;font-weight:600;letter-spacing:.26em;text-transform:uppercase;padding:18px 52px;position:relative;overflow:hidden;transition:border-color .6s var(--ease);}
.btn::before{content:"";position:absolute;inset:0;background:rgba(168,207,224,.12);transform:scaleX(0);transform-origin:left;transition:transform .6s var(--ease);}
.btn span{position:relative;z-index:1;}.btn .arw{position:relative;z-index:1;transition:transform .6s var(--ease);}
.btn:hover{border-color:rgba(168,207,224,.8);}.btn:hover::before{transform:scaleX(1);}.btn:hover .arw{transform:translateX(6px);}

.sf{background:var(--ink);border-top:1px solid var(--line);}
.sf .shell{padding:60px 0 36px;}
.sf__top{display:flex;align-items:center;justify-content:space-between;gap:30px;flex-wrap:wrap;padding-bottom:50px;}
.sf__top .logo img{height:62px;}
.sf__nav{display:flex;flex-wrap:wrap;gap:30px;}
.sf__nav a{font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:rgba(244,246,248,0.72);}.sf__nav a:hover{color:var(--blue-soft);}
.sf__mid{text-align:center;border-top:1px solid var(--line);padding:58px 0 0;}
.sf__mid .big{font-family:var(--serif);font-style:italic;font-size:clamp(30px,5.6vw,72px);color:var(--cream);}
.sf__trust{margin:34px 0 56px;text-align:center;font-size:10.5px;letter-spacing:.2em;text-transform:uppercase;color:rgba(195,220,238,0.66);}
.sf__trust b{font-weight:600;color:var(--blue-soft);}
.sf__base{display:flex;align-items:center;justify-content:space-between;gap:14px;flex-wrap:wrap;border-top:1px solid var(--line);padding-top:24px;}
.sf__base .cr{font-size:11px;color:rgba(244,246,248,0.62);}
.sf__base a{font-size:10.5px;letter-spacing:.18em;text-transform:uppercase;color:rgba(168,207,224,.72);}

.reveal{opacity:0;transform:translateY(22px);transition:opacity .9s var(--ease),transform .9s var(--ease);}
.reveal.in{opacity:1;transform:none;}
@media (prefers-reduced-motion:reduce){.reveal,.hero__photo,.hero .eyebrow,.hero .big{opacity:1!important;transform:none!important;transition:none!important;}*{scroll-behavior:auto!important;}}

@media(max-width:980px){.feat{grid-template-columns:1fr;gap:26px;}.feat:nth-of-type(even) .feat__img{order:0;}.gal{grid-template-columns:1fr 1fr;grid-auto-rows:240px;}.gal a.tall{grid-row:span 1;}}
@media(max-width:900px){
  .shell{padding:0 24px;}.burger{display:flex;}
  .menu{position:fixed;top:0;right:0;bottom:0;width:min(80vw,360px);background:rgba(10,22,40,.97);backdrop-filter:blur(16px);-webkit-backdrop-filter:blur(16px);flex-direction:column;align-items:flex-start;justify-content:center;gap:6px;padding:40px 36px;transform:translateX(100%);transition:transform .6s var(--ease);}
  body.nav-open .menu{transform:none;}
  .menu a{font-size:18px;letter-spacing:.06em;text-transform:none;padding:14px 0;color:var(--cream);}.menu a::after{display:none;}
  .hero{min-height:78vh;padding-bottom:64px;}
  .band{padding:80px 0;}
  .gal{grid-template-columns:1fr;grid-auto-rows:260px;}
  .sf__top,.sf__base{flex-direction:column;align-items:flex-start;gap:14px;}
}
@media(max-width:767px){:root{--hero:url("/images/siglo-hero-768.webp");}}
</style>

<script is:inline>
var hdr=document.getElementById('siteHeader'),prog=document.getElementById('progress'),heroEl=document.getElementById('hero'),hp=document.getElementById('heroPhoto');
var __maxS=0;function __recalc(){__maxS=document.documentElement.scrollHeight-window.innerHeight;}__recalc();window.addEventListener('resize',__recalc,{passive:true});window.addEventListener('load',__recalc);
function onScroll(){var y=window.scrollY,vh=window.innerHeight;hdr.classList.toggle('scrolled',y>40);var h=__maxS;prog.style.width=(h>0?(y/h*100):0)+'%';if(y<vh&&hp){hp.style.transform='translateY('+(y*0.16)+'px) scale(1)';}}
onScroll();window.addEventListener('scroll',onScroll,{passive:true});
requestAnimationFrame(function(){setTimeout(function(){heroEl.classList.add('ready');},140);});
var burger=document.getElementById('burger');function setMenu(o){document.body.classList.toggle('nav-open',o);burger.setAttribute('aria-expanded',o?'true':'false');}
burger.addEventListener('click',function(){setMenu(!document.body.classList.contains('nav-open'));});
document.querySelectorAll('#menu a').forEach(function(a){a.addEventListener('click',function(){setMenu(false);});});
document.addEventListener('keydown',function(e){if(e.key==='Escape')setMenu(false);});
var io=new IntersectionObserver(function(es){es.forEach(function(en){if(en.isIntersecting){var sibs=Array.prototype.slice.call(en.target.parentNode.children).filter(function(c){return c.classList.contains('reveal');});en.target.style.transitionDelay=(Math.max(0,sibs.indexOf(en.target))*0.05)+'s';en.target.classList.add('in');io.unobserve(en.target);}});},{threshold:0.08,rootMargin:'0px 0px -5% 0px'});
document.querySelectorAll('.reveal').forEach(function(el){io.observe(el);});
</script>
